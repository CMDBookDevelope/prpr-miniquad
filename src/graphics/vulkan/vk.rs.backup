impl VulkanContext {
    /// Create a new Vulkan context
    pub fn new() -> Self {
        #[cfg(feature = "vulkan")]
        {
            Self {
                entry: None,
                instance: None,
                device: None,
                allocator: None,
                physical_device: None,
                queue_family_index: None,
                present_queue_family_index: None,
                graphics_queue: None,
                present_queue: None,
                command_pool: None,
                
                // Surface and swapchain
                surface: None,
                swapchain: None,
                swapchain_images: Vec::new(),
                swapchain_image_views: Vec::new(),
                swapchain_image_format: vk::Format::R8G8B8A8_SRGB,
                swapchain_extent: vk::Extent2D { width: 800, height: 600 },
                
                // Render pass and framebuffers
                render_pass: None,
                framebuffers: Vec::new(),
                
                // Command buffers and synchronization
                command_buffers: Vec::new(),
                image_available_semaphores: Vec::new(),
                render_finished_semaphores: Vec::new(),
                in_flight_fences: Vec::new(),
                images_in_flight: Vec::new(),
                
                // Resources
                buffers: HashMap::new(),
                textures: HashMap::new(),
                shaders: Vec::new(),
                pipelines: Vec::new(),
                
                // Frame management
                current_frame: 0,
                max_frames_in_flight: 2,
                msaa_samples: vk::SampleCountFlags::TYPE_4, // Default to 4x MSAA
                display: None,
                next_buffer_id: 0,
                next_texture_id: 0,
                frame_time: 0.0,
                frame_count: 0,
                last_frame_time: std::time::Instant::now(),
            }
        }
        
        #[cfg(not(feature = "vulkan"))]
        {
            Self {
                display: None,
            }
        }
    }

    /// Initialize Vulkan context
    #[cfg(feature = "vulkan")]
    pub fn initialize(&mut self, display: &mut dyn NativeDisplay) -> Result<(), VulkanError> {
        // Store display reference
        self.display = Some(display as *mut _);
        
        // Load Vulkan entry
        self.entry = match unsafe { Entry::load() } {
            Ok(entry) => Some(entry),
            Err(e) => return Err(VulkanError::InitializationFailed(format!("Failed to load Vulkan entry: {}", e))),
        };
        
        // Create Vulkan instance
        self.create_instance()?;
        
        // Create surface
        self.create_surface(display)?;
        
        // Select physical device
        self.select_physical_device()?;
        
        // Create logical device
        self.create_logical_device()?;
        
        // Create allocator
        self.create_allocator()?;
        
        // Create command pool
        self.create_command_pool()?;
        
        // Create swapchain
        self.create_swapchain(display)?;
        
        // Initialize multisampling with default 4x MSAA
        self.initialize_multisampling(4)?;
        
        // Create render pass with MSAA support
        self.create_render_pass()?;
        
        // Create framebuffers with MSAA support
        self.create_framebuffers()?;
        
        Ok(())
    }

    #[cfg(not(feature = "vulkan"))]
    pub fn initialize(&mut self, _display: &mut dyn NativeDisplay) -> Result<(), VulkanError> {
        Err(VulkanError::NotAvailable)
    }

    #[cfg(feature = "vulkan")]
    fn create_instance(&mut self) -> Result<(), VulkanError> {
        let app_name = CStr::from_bytes_with_nul(b"miniquad-vulkan\0").unwrap();
        let engine_name = CStr::from_bytes_with_nul(b"miniquad\0").unwrap();
        
        let app_info = vk::ApplicationInfo {
            p_application_name: app_name.as_ptr(),
            application_version: vk::make_api_version(0, 1, 0, 0),
            p_engine_name: engine_name.as_ptr(),
            engine_version: vk::make_api_version(0, 1, 0, 0),
            api_version: vk::API_VERSION_1_0,
            ..Default::default()
        };
            
        let extensions = self.get_required_instance_extensions()?;
        
        let create_info = vk::InstanceCreateInfo {
            p_application_info: &app_info,
            enabled_extension_count: extensions.len() as u32,
            pp_enabled_extension_names: extensions.as_ptr(),
            ..Default::default()
        };
            
        let instance = unsafe { 
            self.entry.as_ref().unwrap().create_instance(&create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create Vulkan instance: {}", e)))?
        };
        self.instance = Some(instance);
        
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn get_required_instance_extensions(&self) -> Result<Vec<*const i8>, VulkanError> {
        // For now, return empty extensions list
        // TODO: Add platform-specific extensions for surface creation
        Ok(Vec::new())
    }

    #[cfg(feature = "vulkan")]
    fn create_surface(&mut self, _display: &dyn NativeDisplay) -> Result<(), VulkanError> {
        // Simplified surface creation - placeholder implementation
        println!("Creating Vulkan surface (placeholder implementation)");
        self.surface = None; // No surface for now
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn select_physical_device(&mut self) -> Result<(), VulkanError> {
        let physical_devices = unsafe {
            self.instance.as_ref().unwrap().enumerate_physical_devices()
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to enumerate physical devices: {}", e)))?
        };
        
        // Find a suitable physical device
        for device in physical_devices {
            let properties = unsafe { self.instance.as_ref().unwrap().get_physical_device_properties(device) };
            
            // Check if the device supports the required features
            if self.is_device_suitable(device) {
                self.physical_device = Some(device);
                return Ok(());
            }
        }
        
        Err(VulkanError::FeatureNotPresent("No suitable Vulkan device found".to_string()))
    }

    #[cfg(feature = "vulkan")]
    fn is_device_suitable(&self, physical_device: vk::PhysicalDevice) -> bool {
        let properties = unsafe { self.instance.as_ref().unwrap().get_physical_device_properties(physical_device) };
        
        // Check for Vulkan 1.0 support
        if properties.api_version < vk::API_VERSION_1_0 {
            return false;
        }
        
        // Check for graphics queue family
        let queue_families = unsafe {
            self.instance.as_ref().unwrap().get_physical_device_queue_family_properties(physical_device)
        };
        
        // Simplified: just check for graphics support
        queue_families.iter().any(|queue_family| {
            queue_family.queue_flags.contains(vk::QueueFlags::GRAPHICS)
        })
    }

    #[cfg(feature = "vulkan")]
    fn create_logical_device(&mut self) -> Result<(), VulkanError> {
        let physical_device = self.physical_device.unwrap();
        let instance = self.instance.as_ref().unwrap();
        
        // Find graphics and present queue families
        let queue_families = unsafe {
            instance.get_physical_device_queue_family_properties(physical_device)
        };
        
        let mut graphics_family = None;
        let mut present_family = None;
        
        for (index, queue_family) in queue_families.iter().enumerate() {
            if queue_family.queue_flags.contains(vk::QueueFlags::GRAPHICS) {
                graphics_family = Some(index as u32);
            }
            
            // Check if this queue family supports present
            let surface = self.surface.ok_or(VulkanError::DeviceNotInitialized)?;
            let present_support = unsafe {
                // For ash v0.38+, use the new method signature
                #[cfg(feature = "ash_038")]
                {
                    instance.get_physical_device_surface_support_khr(physical_device, index as u32, surface)
                        .map_err(|e| VulkanError::InitializationFailed(format!("Failed to check surface support: {}", e)))?
                }
                
                // For ash v0.37 and below
                #[cfg(not(feature = "ash_038"))]
                {
                    instance.get_physical_device_surface_support_khr(physical_device, index as u32, surface)
                }
            };
            
            if present_support {
                present_family = Some(index as u32);
            }
            
            if graphics_family.is_some() && present_family.is_some() {
                break;
            }
        }
        
        let graphics_family = graphics_family.ok_or(VulkanError::FeatureNotPresent("No graphics queue family found".to_string()))?;
        let present_family = present_family.unwrap_or(graphics_family);
        
        self.queue_family_index = Some(graphics_family);
        self.present_queue_family_index = Some(present_family);
        
        // Create queue create infos
        let mut queue_create_infos = Vec::new();
        let mut unique_queue_families = vec![graphics_family, present_family];
        unique_queue_families.sort();
        unique_queue_families.dedup();
        
        for &queue_family in &unique_queue_families {
            queue_create_infos.push(vk::DeviceQueueCreateInfo {
                queue_family_index: queue_family,
                queue_count: 1,
                p_queue_priorities: [1.0f32].as_ptr(),
                ..Default::default()
            });
        }
        
        let device_create_info = vk::DeviceCreateInfo {
            queue_create_info_count: queue_create_infos.len() as u32,
            p_queue_create_infos: queue_create_infos.as_ptr(),
            ..Default::default()
        };
            
        let device = unsafe {
            instance.create_device(physical_device, &device_create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create logical device: {}", e)))?
        };
        self.device = Some(device);
        
        // Get graphics and present queues
        self.graphics_queue = Some(unsafe {
            self.device.as_ref().unwrap().get_device_queue(graphics_family, 0)
        });
        
        self.present_queue = Some(unsafe {
            self.device.as_ref().unwrap().get_device_queue(present_family, 0)
        });
        
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn create_allocator(&mut self) -> Result<(), VulkanError> {
        let allocator_create_desc = AllocatorCreateDesc {
            instance: self.instance.as_ref().unwrap().clone(),
            device: self.device.as_ref().unwrap().clone(),
            physical_device: self.physical_device.unwrap(),
            debug_settings: Default::default(),
            buffer_device_address: false,
            allocation_sizes: Default::default(),
        };
        
        let allocator = Arc::new(
            Allocator::new(&allocator_create_desc)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create allocator: {}", e)))?
        );
        self.allocator = Some(allocator);
        
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn create_command_pool(&mut self) -> Result<(), VulkanError> {
        let command_pool_info = vk::CommandPoolCreateInfo {
            flags: vk::CommandPoolCreateFlags::RESET_COMMAND_BUFFER,
            queue_family_index: self.queue_family_index.unwrap(),
            ..Default::default()
        };
            
        let command_pool = unsafe {
            self.device.as_ref().unwrap()
                .create_command_pool(&command_pool_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create command pool: {}", e)))?
        };
        self.command_pool = Some(command_pool);
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn create_swapchain(&mut self, _display: &dyn NativeDisplay) -> Result<(), VulkanError> {
        // Simplified swapchain creation - placeholder implementation
        println!("Creating Vulkan swapchain (placeholder implementation)");
        self.swapchain = None;
        self.swapchain_images.clear();
        self.swapchain_image_views.clear();
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn initialize_multisampling(&mut self, sample_count: i32) -> Result<(), VulkanError> {
        // Set MSAA samples based on configuration
        self.set_msaa_samples(sample_count)?;
        
        // Validate MSAA support
        let physical_device = self.physical_device.ok_or(VulkanError::DeviceNotInitialized)?;
        let instance = self.instance.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        
        let properties = unsafe {
            instance.get_physical_device_properties(physical_device)
        };
        
        let supported_sample_counts = properties.limits.framebuffer_color_sample_counts 
            & properties.limits.framebuffer_depth_sample_counts;
        
        if !supported_sample_counts.contains(self.msaa_samples) {
            // Fall back to highest supported sample count
            let fallback_samples = match self.msaa_samples {
                vk::SampleCountFlags::TYPE_64 => {
                    if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_32) { vk::SampleCountFlags::TYPE_32 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_16) { vk::SampleCountFlags::TYPE_16 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_8) { vk::SampleCountFlags::TYPE_8 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_4) { vk::SampleCountFlags::TYPE_4 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_2) { vk::SampleCountFlags::TYPE_2 }
                    else { vk::SampleCountFlags::TYPE_1 }
                },
                vk::SampleCountFlags::TYPE_32 => {
                    if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_16) { vk::SampleCountFlags::TYPE_16 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_8) { vk::SampleCountFlags::TYPE_8 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_4) { vk::SampleCountFlags::TYPE_4 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_2) { vk::SampleCountFlags::TYPE_2 }
                    else { vk::SampleCountFlags::TYPE_1 }
                },
                vk::SampleCountFlags::TYPE_16 => {
                    if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_8) { vk::SampleCountFlags::TYPE_8 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_4) { vk::SampleCountFlags::TYPE_4 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_2) { vk::SampleCountFlags::TYPE_2 }
                    else { vk::SampleCountFlags::TYPE_1 }
                },
                vk::SampleCountFlags::TYPE_8 => {
                    if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_4) { vk::SampleCountFlags::TYPE_4 }
                    else if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_2) { vk::SampleCountFlags::TYPE_2 }
                    else { vk::SampleCountFlags::TYPE_1 }
                },
                vk::SampleCountFlags::TYPE_4 => {
                    if supported_sample_counts.contains(vk::SampleCountFlags::TYPE_2) { vk::SampleCountFlags::TYPE_2 }
                    else { vk::SampleCountFlags::TYPE_1 }
                },
                _ => self.msaa_samples,
            };
            
            self.msaa_samples = fallback_samples;
        }
        
        Ok(())
    }
    
    #[cfg(feature = "vulkan")]
    fn create_render_pass(&mut self) -> Result<(), VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Color attachment
        let color_attachment = vk::AttachmentDescription {
            format: self.swapchain_image_format,
            samples: self.msaa_samples,
            load_op: vk::AttachmentLoadOp::CLEAR,
            store_op: vk::AttachmentStoreOp::STORE,
            stencil_load_op: vk::AttachmentLoadOp::DONT_CARE,
            stencil_store_op: vk::AttachmentStoreOp::DONT_CARE,
            initial_layout: vk::ImageLayout::UNDEFINED,
            final_layout: vk::ImageLayout::COLOR_ATTACHMENT_OPTIMAL,
            ..Default::default()
        };
        
        // Resolve attachment (for MSAA resolve)
        let color_resolve_attachment = vk::AttachmentDescription {
            format: self.swapchain_image_format,
            samples: vk::SampleCountFlags::TYPE_1,
            load_op: vk::AttachmentLoadOp::DONT_CARE,
            store_op: vk::AttachmentStoreOp::STORE,
            stencil_load_op: vk::AttachmentLoadOp::DONT_CARE,
            stencil_store_op: vk::AttachmentStoreOp::DONT_CARE,
            initial_layout: vk::ImageLayout::UNDEFINED,
            final_layout: vk::ImageLayout::PRESENT_SRC_KHR,
            ..Default::default()
        };
        
        // Depth attachment
        let depth_attachment = vk::AttachmentDescription {
            format: vk::Format::D32_SFLOAT,
            samples: self.msaa_samples,
            load_op: vk::AttachmentLoadOp::CLEAR,
            store_op: vk::AttachmentStoreOp::DONT_CARE,
            stencil_load_op: vk::AttachmentLoadOp::DONT_CARE,
            stencil_store_op: vk::AttachmentStoreOp::DONT_CARE,
            initial_layout: vk::ImageLayout::UNDEFINED,
            final_layout: vk::ImageLayout::DEPTH_STENCIL_ATTACHMENT_OPTIMAL,
            ..Default::default()
        };
        
        // Attachment references
        let color_attachment_ref = vk::AttachmentReference {
            attachment: 0,
            layout: vk::ImageLayout::COLOR_ATTACHMENT_OPTIMAL,
        };
        
        let color_resolve_ref = vk::AttachmentReference {
            attachment: 1,
            layout: vk::ImageLayout::COLOR_ATTACHMENT_OPTIMAL,
        };
        
        let depth_attachment_ref = vk::AttachmentReference {
            attachment: 2,
            layout: vk::ImageLayout::DEPTH_STENCIL_ATTACHMENT_OPTIMAL,
        };
        
        // Subpass
        let subpass = vk::SubpassDescription {
            pipeline_bind_point: vk::PipelineBindPoint::GRAPHICS,
            color_attachment_count: 1,
            p_color_attachments: &color_attachment_ref,
            p_resolve_attachments: &color_resolve_ref,
            p_depth_stencil_attachment: &depth_attachment_ref,
            ..Default::default()
        };
        
        // Subpass dependency
        let dependency = vk::SubpassDependency {
            src_subpass: vk::SUBPASS_EXTERNAL,
            dst_subpass: 0,
            src_stage_mask: vk::PipelineStageFlags::COLOR_ATTACHMENT_OUTPUT 
                | vk::PipelineStageFlags::EARLY_FRAGMENT_TESTS,
            src_access_mask: vk::AccessFlags::empty(),
            dst_stage_mask: vk::PipelineStageFlags::COLOR_ATTACHMENT_OUTPUT 
                | vk::PipelineStageFlags::EARLY_FRAGMENT_TESTS,
            dst_access_mask: vk::AccessFlags::COLOR_ATTACHMENT_WRITE 
                | vk::AccessFlags::DEPTH_STENCIL_ATTACHMENT_WRITE,
            ..Default::default()
        };
        
        // Create render pass
        let attachments = [color_attachment, color_resolve_attachment, depth_attachment];
        let subpasses = [subpass];
        let dependencies = [dependency];
        
        let render_pass_info = vk::RenderPassCreateInfo {
            attachment_count: attachments.len() as u32,
            p_attachments: attachments.as_ptr(),
            subpass_count: subpasses.len() as u32,
            p_subpasses: subpasses.as_ptr(),
            dependency_count: dependencies.len() as u32,
            p_dependencies: dependencies.as_ptr(),
            ..Default::default()
        };
        
        let render_pass = unsafe {
            device.create_render_pass(&render_pass_info, None)
                .map_err(|e| VulkanError::RenderPassCreationFailed(format!("Failed to create render pass: {}", e)))?
        };
        
        self.render_pass = Some(render_pass);
        
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn create_framebuffers(&mut self) -> Result<(), VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        let render_pass = self.render_pass.ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Clear existing framebuffers
        self.framebuffers.clear();
        
        // Validate MSAA support
        let physical_device = self.physical_device.ok_or(VulkanError::DeviceNotInitialized)?;
        let instance = self.instance.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        let properties = unsafe {
            instance.get_physical_device_properties(physical_device)
        };
        
        let supported_sample_counts = properties.limits.framebuffer_color_sample_counts 
            & properties.limits.framebuffer_depth_sample_counts;
        
        if !supported_sample_counts.contains(self.msaa_samples) {
            return Err(VulkanError::MultisamplingFailed(
                format!("Requested MSAA sample count {:?} not supported", self.msaa_samples)
            ));
        }
        
        // Create framebuffers for each swapchain image
        for &image_view in &self.swapchain_image_views {
            // Create multisample color attachment
            let multisample_color_image = self.create_multisample_texture(
                self.swapchain_extent.width,
                self.swapchain_extent.height
            )?;
            
            let multisample_texture = &self.textures[&multisample_color_image];
            
            // Create depth image
            let depth_image_create_info = vk::ImageCreateInfo {
                image_type: vk::ImageType::TYPE_2D,
                extent: vk::Extent3D {
                    width: self.swapchain_extent.width,
                    height: self.swapchain_extent.height,
                    depth: 1,
                },
                mip_levels: 1,
                array_layers: 1,
                format: vk::Format::D32_SFLOAT,
                tiling: vk::ImageTiling::OPTIMAL,
                initial_layout: vk::ImageLayout::UNDEFINED,
                usage: vk::ImageUsageFlags::DEPTH_STENCIL_ATTACHMENT,
                sharing_mode: vk::SharingMode::EXCLUSIVE,
                samples: self.msaa_samples,
                ..Default::default()
            };
            
            let depth_image = unsafe {
                device.create_image(&depth_image_create_info, None)
                    .map_err(|e| VulkanError::ImageCreationFailed(format!("Failed to create depth image: {}", e)))?
            };
            
            // Allocate memory for depth image
            let depth_requirements = unsafe { device.get_image_memory_requirements(depth_image) };
            let depth_allocation_info = vk::MemoryAllocateInfo {
                allocation_size: depth_requirements.size,
                memory_type_index: self.find_memory_type(depth_requirements.memory_type_bits, vk::MemoryPropertyFlags::DEVICE_LOCAL),
                ..Default::default()
            };
            
            let depth_memory = unsafe {
                device.allocate_memory(&depth_allocation_info, None)
                    .map_err(|e| VulkanError::AllocationFailed(format!("Failed to allocate depth memory: {}", e)))?
            };
            
            unsafe {
                device.bind_image_memory(depth_image, depth_memory, 0)
                    .map_err(|e| VulkanError::AllocationFailed(format!("Failed to bind depth memory: {}", e)))?;
            }
            
            // Create depth image view
            let depth_view_create_info = vk::ImageViewCreateInfo {
                image: depth_image,
                view_type: vk::ImageViewType::TYPE_2D,
                format: vk::Format::D32_SFLOAT,
                components: vk::ComponentMapping {
                    r: vk::ComponentSwizzle::IDENTITY,
                    g: vk::ComponentSwizzle::IDENTITY,
                    b: vk::ComponentSwizzle::IDENTITY,
                    a: vk::ComponentSwizzle::IDENTITY,
                },
                subresource_range: vk::ImageSubresourceRange {
                    aspect_mask: vk::ImageAspectFlags::DEPTH,
                    base_mip_level: 0,
                    level_count: 1,
                    base_array_layer: 0,
                    layer_count: 1,
                },
                ..Default::default()
            };
            
            let depth_image_view = unsafe {
                device.create_image_view(&depth_view_create_info, None)
                    .map_err(|e| VulkanError::ImageCreationFailed(format!("Failed to create depth image view: {}", e)))?
            };
            
            // Create framebuffer
            let attachments = [
                multisample_texture.image_view,
                image_view,
                depth_image_view,
            ];
            
            let framebuffer_create_info = vk::FramebufferCreateInfo {
                s_type: vk::StructureType::FRAMEBUFFER_CREATE_INFO,
                p_next: std::ptr::null(),
                flags: vk::FramebufferCreateFlags::empty(),
                render_pass,
                attachment_count: attachments.len() as u32,
                p_attachments: attachments.as_ptr(),
                width: self.swapchain_extent.width,
                height: self.swapchain_extent.height,
                layers: 1,
                ..Default::default()
            };
            
            let framebuffer = unsafe {
                device.create_framebuffer(&framebuffer_create_info, None)
                    .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create framebuffer: {}", e)))?
            };
            
            self.framebuffers.push(framebuffer);
        }
        
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn create_sync_objects(&mut self) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        // Clear existing objects
        self.image_available_semaphores.clear();
        self.render_finished_semaphores.clear();
        self.in_flight_fences.clear();
        self.images_in_flight.clear();
        
        // Create synchronization objects for each frame in flight
        for _ in 0..self.max_frames_in_flight {
            // Create image available semaphore
            let semaphore_info = vk::SemaphoreCreateInfo {
                ..Default::default()
            };
            
            let image_available_semaphore = unsafe {
                device.create_semaphore(&semaphore_info, None)
                    .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create image available semaphore: {}", e)))?
            };
            
            // Create render finished semaphore
            let render_finished_semaphore = unsafe {
                device.create_semaphore(&semaphore_info, None)
                    .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create render finished semaphore: {}", e)))?
            };
            
            // Create fence
            let fence_info = vk::FenceCreateInfo {
                flags: vk::FenceCreateFlags::SIGNALED, // Start as signaled to avoid waiting on first frame
                ..Default::default()
            };
            
            let fence = unsafe {
                device.create_fence(&fence_info, None)
                    .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create fence: {}", e)))?
            };
            
            self.image_available_semaphores.push(image_available_semaphore);
            self.render_finished_semaphores.push(render_finished_semaphore);
            self.in_flight_fences.push(fence);
            self.images_in_flight.push(None);
        }
        
        Ok(())
    }

    #[cfg(feature = "vulkan")]
    fn create_command_buffers(&mut self) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        // Clear existing command buffers
        self.command_buffers.clear();
        
        // Create command buffers for each swapchain image
        for _ in 0..self.swapchain_images.len() {
            let command_buffer_allocate_info = vk::CommandBufferAllocateInfo {
                s_type: vk::StructureType::COMMAND_BUFFER_ALLOCATE_INFO,
                p_next: std::ptr::null(),
                command_pool: self.command_pool.unwrap(),
                level: vk::CommandBufferLevel::PRIMARY,
                command_buffer_count: 1,
                ..Default::default()
            };
            
            let command_buffers = unsafe {
                device.allocate_command_buffers(&command_buffer_allocate_info)
                    .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to allocate command buffer: {}", e)))?
            };
            
            self.command_buffers.push(command_buffers[0]);
        }
        
        Ok(())
    }

    /// Check if Vulkan is available
    pub fn is_available() -> bool {
        #[cfg(feature = "vulkan")]
        {
            // Try to load Vulkan entry
            unsafe { Entry::load().is_ok() }
        }
        
        #[cfg(not(feature = "vulkan"))]
        {
            false
        }
    }
    
    #[cfg(feature = "vulkan")]
    pub fn set_msaa_samples(&mut self, samples: i32) -> Result<(), VulkanError> {
        match samples {
            1 => self.msaa_samples = vk::SampleCountFlags::TYPE_1,
            2 => self.msaa_samples = vk::SampleCountFlags::TYPE_2,
            4 => self.msaa_samples = vk::SampleCountFlags::TYPE_4,
            8 => self.msaa_samples = vk::SampleCountFlags::TYPE_8,
            16 => self.msaa_samples = vk::SampleCountFlags::TYPE_16,
            32 => self.msaa_samples = vk::SampleCountFlags::TYPE_32,
            64 => self.msaa_samples = vk::SampleCountFlags::TYPE_64,
            _ => return Err(VulkanError::MultisamplingFailed(
                format!("Invalid MSAA sample count: {}", samples)
            )),
        }
        Ok(())
    }

    // Resource management methods
    
    /// Create a buffer
    #[cfg(feature = "vulkan")]
    pub fn create_buffer(&mut self, size: vk::DeviceSize, usage: vk::BufferUsageFlags, memory_usage: MemoryLocation) -> Result<usize, VulkanError> {
        let device = self.device.as_ref().unwrap();
        let allocator = self.allocator.as_ref().unwrap();
        
        // Create buffer
        let create_info = vk::BufferCreateInfo {
            size,
            usage,
            sharing_mode: vk::SharingMode::EXCLUSIVE,
            ..Default::default()
        };
            
        let buffer = unsafe {
            device.create_buffer(&create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create buffer: {}", e)))?
        };
        
        // Get memory requirements
        let requirements = unsafe { device.get_buffer_memory_requirements(buffer) };
        let location = memory_usage;
        
let allocation_create_desc = gpu_allocator::vulkan::AllocationCreateDesc {
            name: "Buffer",
            requirements,
            location,
            linear: true,
            allocation_scheme: gpu_allocator::vulkan::AllocationScheme::DedicatedBuffer(buffer),
        };

        // Create allocation using the allocator
                let (allocation, memory) = {
                    // Use a simplified allocation approach for now
                    // In a full implementation, we would use the gpu-allocator properly
                    let allocation_info = vk::MemoryAllocateInfo {
                        allocation_size: requirements.size,
                        memory_type_index: self.find_memory_type(requirements.memory_type_bits, 
                            if location == MemoryLocation::CpuToGpu { 
                                vk::MemoryPropertyFlags::HOST_VISIBLE | vk::MemoryPropertyFlags::HOST_COHERENT 
                            } else { 
                                vk::MemoryPropertyFlags::DEVICE_LOCAL 
                            }),
                        ..Default::default()
                    };
                    
                    let memory = unsafe {
                        device.allocate_memory(&allocation_info, None)
                            .map_err(|e| VulkanError::OutOfMemory)?
                    };
                    
                    let allocation = gpu_allocator::vulkan::Allocation::default();                    (allocation, memory)
                };
        
                // Bind memory (simplified - in real implementation would use proper allocation)
                unsafe {
                    device.bind_buffer_memory(buffer, memory, 0)
                        .map_err(|e| VulkanError::InitializationFailed(format!("Failed to bind buffer memory: {}", e)))?
                }        
        let buffer_id = self.next_buffer_id;
        self.next_buffer_id += 1;
        
        self.buffers.insert(buffer_id, VulkanBuffer {
            buffer,
            allocation,
            size,
            usage,
        });
        
        Ok(buffer_id)
    }

