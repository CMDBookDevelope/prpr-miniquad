    /// Create a texture
    #[cfg(feature = "vulkan")]
    pub fn create_texture(&mut self, width: u32, height: u32, data: &[u8]) -> Result<usize, VulkanError> {
        let device = self.device.as_ref().unwrap();
        let allocator = self.allocator.as_ref().unwrap();
        
        // Create image
        let create_info = vk::ImageCreateInfo {
            image_type: vk::ImageType::TYPE_2D,
            extent: vk::Extent3D {
                width,
                height,
                depth: 1,
            },
            mip_levels: 1,
            array_layers: 1,
            format: vk::Format::R8G8B8A8_SRGB,
            tiling: vk::ImageTiling::OPTIMAL,
            initial_layout: vk::ImageLayout::UNDEFINED,
            usage: vk::ImageUsageFlags::TRANSFER_DST | vk::ImageUsageFlags::SAMPLED,
            sharing_mode: vk::SharingMode::EXCLUSIVE,
            samples: vk::SampleCountFlags::TYPE_1,
            ..Default::default()
        };
            
        let image = unsafe {
            device.create_image(&create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create image: {}", e)))?
        };
        // Allocate memory
                let requirements = unsafe { device.get_image_memory_requirements(image) };
                let location = MemoryLocation::GpuOnly;
                let allocation_create_desc = gpu_allocator::vulkan::AllocationCreateDesc {
                    name: "Texture",
                    requirements,
                    location,
                    linear: false,
                    allocation_scheme: gpu_allocator::vulkan::AllocationScheme::DedicatedImage(image),
                };
                // Create allocation using the allocator
                        let (allocation, memory) = {
                            let allocation_info = vk::MemoryAllocateInfo {
                                allocation_size: requirements.size,
                                memory_type_index: self.find_memory_type(requirements.memory_type_bits,
                                    vk::MemoryPropertyFlags::DEVICE_LOCAL),
                                ..Default::default()
                            };
                            let memory = unsafe {
                                device.allocate_memory(&allocation_info, None)
                                    .map_err(|e| VulkanError::OutOfMemory)?
                            };
                            let allocation = gpu_allocator::vulkan::Allocation::default();
                            (allocation, memory)
                        };
                        // Bind memory (simplified - in real implementation would use proper allocation)
                        unsafe {
                            device.bind_image_memory(image, memory, 0)
                                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to bind image memory: {}", e)))?
                        }
        // Create image view
        let view_create_info = vk::ImageViewCreateInfo {
            image,
            view_type: vk::ImageViewType::TYPE_2D,
            format: vk::Format::R8G8B8A8_SRGB,
            components: vk::ComponentMapping {
                r: vk::ComponentSwizzle::IDENTITY,
                g: vk::ComponentSwizzle::IDENTITY,
                b: vk::ComponentSwizzle::IDENTITY,
                a: vk::ComponentSwizzle::IDENTITY,
            },
            subresource_range: vk::ImageSubresourceRange {
                aspect_mask: vk::ImageAspectFlags::COLOR,
                base_mip_level: 0,
                level_count: 1,
                base_array_layer: 0,
                layer_count: 1,
            },
            ..Default::default()
        };
            
        let image_view = unsafe {
            device.create_image_view(&view_create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create image view: {}", e)))?
        };
        
        // Create sampler
        let sampler_info = vk::SamplerCreateInfo {
            mag_filter: vk::Filter::LINEAR,
            min_filter: vk::Filter::LINEAR,
            address_mode_u: vk::SamplerAddressMode::REPEAT,
            address_mode_v: vk::SamplerAddressMode::REPEAT,
            address_mode_w: vk::SamplerAddressMode::REPEAT,
            anisotropy_enable: vk::FALSE,
            border_color: vk::BorderColor::INT_OPAQUE_BLACK,
            unnormalized_coordinates: vk::FALSE,
            compare_enable: vk::FALSE,
            compare_op: vk::CompareOp::ALWAYS,
            mipmap_mode: vk::SamplerMipmapMode::LINEAR,
            mip_lod_bias: 0.0,
            min_lod: 0.0,
            max_lod: vk::LOD_CLAMP_NONE,
            ..Default::default()
        };
            
        let sampler = unsafe {
            device.create_sampler(&sampler_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create sampler: {}", e)))?
        };
        
        // Upload texture data (simplified - in real implementation would use staging buffer)
        if !data.is_empty() {
            self.update_texture_data(image, data, width, height)?;
        }
        
        let texture_id = self.next_texture_id;
        self.next_texture_id += 1;
        
        self.textures.insert(texture_id, VulkanTexture {
            image,
            image_view,
            allocation,
            sampler,
            width,
            height,
            format: vk::Format::R8G8B8A8_SRGB,
        });
        
        Ok(texture_id)
    }

    #[cfg(feature = "vulkan")]
    pub fn create_multisample_texture(&mut self, width: u32, height: u32) -> Result<usize, VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        let allocator = self.allocator.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Create multisample image
        let create_info = vk::ImageCreateInfo {
            image_type: vk::ImageType::TYPE_2D,
            extent: vk::Extent3D {
                width,
                height,
                depth: 1,
            },
            mip_levels: 1,
            array_layers: 1,
            format: vk::Format::R8G8B8A8_SRGB,
            tiling: vk::ImageTiling::OPTIMAL,
            initial_layout: vk::ImageLayout::UNDEFINED,
            usage: vk::ImageUsageFlags::COLOR_ATTACHMENT | vk::ImageUsageFlags::TRANSIENT_ATTACHMENT,
            sharing_mode: vk::SharingMode::EXCLUSIVE,
            samples: self.msaa_samples,
            ..Default::default()
        };
            
        let image = unsafe {
            device.create_image(&create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create multisample image: {}", e)))?
        };
        
        // Create image view
        let view_create_info = vk::ImageViewCreateInfo {
            image,
            view_type: vk::ImageViewType::TYPE_2D,
            format: vk::Format::R8G8B8A8_SRGB,
            subresource_range: vk::ImageSubresourceRange {
                aspect_mask: vk::ImageAspectFlags::COLOR,
                base_mip_level: 0,
                level_count: 1,
                base_array_layer: 0,
                layer_count: 1,
            },
            ..Default::default()
        };
        
        let image_view = unsafe {
            device.create_image_view(&view_create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create image view: {}", e)))?
        };
        
        // Create allocation (simplified)
        let allocation = gpu_allocator::vulkan::Allocation::default();
        
        let texture_id = self.next_texture_id;
        self.next_texture_id += 1;
        
        self.textures.insert(texture_id, VulkanTexture {
            image,
            image_view,
            allocation,
            sampler: vk::Sampler::null(), // Multisample textures don't need samplers
            width,
            height,
            format: vk::Format::R8G8B8A8_SRGB,
        });
        
        Ok(texture_id)
    }

    /// Update texture data
    #[cfg(feature = "vulkan")]
    pub fn update_texture_data(&mut self, image: vk::Image, data: &[u8], width: u32, height: u32) -> Result<(), VulkanError> {
        if data.is_empty() {
            return Ok(());
        }
        
        let device = self.device.as_ref().unwrap();
        let command_pool = self.command_pool.ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Create staging buffer
        let staging_buffer_id = self.create_buffer(
            data.len() as vk::DeviceSize,
            vk::BufferUsageFlags::TRANSFER_SRC,
            MemoryLocation::CpuToGpu,
        )?;
        
        // Get staging buffer
        let staging_buffer = &self.buffers[&staging_buffer_id];
        
        // Map staging buffer and upload data
        unsafe {
            let mut staging_data = std::ptr::null_mut();
            
            // Fix map_memory call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                let result = device.map_memory(staging_buffer.allocation.memory(), data.len().try_into().unwrap(), &mut staging_data);
                match result {
                    Ok(()) => {
                        std::ptr::copy_nonoverlapping(data.as_ptr(), staging_data as *mut u8, data.len());
                        device.unmap_memory(staging_buffer.allocation.memory());
                    }
                    Err(err) => return Err(VulkanError::MappingFailed(format!("Failed to map staging buffer memory: {:?}", err))),
                }
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                let result = device.map_memory(staging_buffer.allocation.memory(), staging_buffer.allocation.offset(), data.len(), vk::MemoryMapFlags::empty(), &mut staging_data);
                match result {
                    vk::Result::SUCCESS => {
                        std::ptr::copy_nonoverlapping(data.as_ptr(), staging_data as *mut u8, data.len());
                        device.unmap_memory(staging_buffer.allocation.memory());
                    }
                    err => return Err(VulkanError::MappingFailed(format!("Failed to map staging buffer memory: {:?}", err))),
                }
            }
        }
        
        // Create command buffer for texture upload
        let command_buffer_allocate_info = vk::CommandBufferAllocateInfo {
            s_type: vk::StructureType::COMMAND_BUFFER_ALLOCATE_INFO,
            p_next: std::ptr::null(),
            command_pool,
            level: vk::CommandBufferLevel::PRIMARY,
            command_buffer_count: 1,
            ..Default::default()
        };
        
        let command_buffers = unsafe {
            device.allocate_command_buffers(&command_buffer_allocate_info)
                .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to allocate command buffer for texture upload: {}", e)))?
        };
        
        let upload_command_buffer = command_buffers[0];
        
        // Begin command buffer
        let begin_info = vk::CommandBufferBeginInfo {
            s_type: vk::StructureType::COMMAND_BUFFER_BEGIN_INFO,
            p_next: std::ptr::null(),
            flags: vk::CommandBufferUsageFlags::ONE_TIME_SUBMIT,
            p_inheritance_info: std::ptr::null(),
            ..Default::default()
        };
        
        unsafe {
            device.begin_command_buffer(upload_command_buffer, &begin_info)
                .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to begin upload command buffer: {}", e)))?;
        }
        
        // Transition image to transfer destination layout
        self.cmd_pipeline_barrier(
            upload_command_buffer,
            vk::PipelineStageFlags::TOP_OF_PIPE,
            vk::PipelineStageFlags::TRANSFER,
            image,
            vk::ImageLayout::UNDEFINED,
            vk::ImageLayout::TRANSFER_DST_OPTIMAL
        )?;
        
        // Copy buffer to image
        let image_subresource = vk::ImageSubresourceLayers {
            aspect_mask: vk::ImageAspectFlags::COLOR,
            mip_level: 0,
            base_array_layer: 0,
            layer_count: 1,
        };
        
        let image_offset = vk::Offset3D { x: 0, y: 0, z: 0 };
        let image_extent = vk::Extent3D { width, height, depth: 1 };
        
        let buffer_to_image = vk::BufferImageCopy {
            buffer_offset: 0,
            buffer_row_length: 0,
            buffer_image_height: 0,
            image_subresource,
            image_offset,
            image_extent,
        };
        
        unsafe {
            // Fix cmd_copy_buffer_to_image call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                device.cmd_copy_buffer_to_image(
                    upload_command_buffer,
                    staging_buffer.buffer,
                    image,
                    vk::ImageLayout::TRANSFER_DST_OPTIMAL,
                    &[buffer_to_image]
                );
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                device.cmd_copy_buffer_to_image(
                    upload_command_buffer,
                    staging_buffer.buffer,
                    image,
                    vk::ImageLayout::TRANSFER_DST_OPTIMAL,
                    1,
                    [buffer_to_image].as_ptr()
                );
            }
        }
        
        // Transition image to shader read-only layout
        self.cmd_pipeline_barrier(
            upload_command_buffer,
            vk::PipelineStageFlags::TRANSFER,
            vk::PipelineStageFlags::FRAGMENT_SHADER,
            image,
            vk::ImageLayout::TRANSFER_DST_OPTIMAL,
            vk::ImageLayout::SHADER_READ_ONLY_OPTIMAL
        )?;
        
        // End command buffer
        unsafe {
            device.end_command_buffer(upload_command_buffer)
                .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to end upload command buffer: {}", e)))?;
        }
        
        // Submit command buffer
        let submit_info = vk::SubmitInfo {
            s_type: vk::StructureType::SUBMIT_INFO,
            p_next: std::ptr::null(),
            wait_semaphore_count: 0,
            p_wait_semaphores: std::ptr::null(),
            p_wait_dst_stage_mask: std::ptr::null(),
            command_buffer_count: 1,
            p_command_buffers: &upload_command_buffer,
            signal_semaphore_count: 0,
            p_signal_semaphores: std::ptr::null(),
            ..Default::default()
        };
        
        let graphics_queue = self.graphics_queue.ok_or(VulkanError::DeviceNotInitialized)?;
        
        unsafe {
            device.queue_submit(graphics_queue, &[submit_info], vk::Fence::null())
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to submit texture upload: {}", e)))?;
            
            // Wait for upload to complete
            device.queue_wait_idle(graphics_queue)
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to wait for texture upload: {}", e)))?;
        }
        
        // Free command buffer
        unsafe {
            device.free_command_buffers(command_pool, &[upload_command_buffer]);
        }
        
        // Clean up staging buffer
        self.delete_buffer(staging_buffer_id);
        
        println!("Successfully updated texture {}x{} with {} bytes", width, height, data.len());
        
        Ok(())
    }
    /// Create a graphics shader
    #[cfg(feature = "vulkan")]
    pub fn create_shader(&mut self, vertex_shader: &str, fragment_shader: &str, meta: ShaderMeta) -> Result<usize, VulkanError> {
        self.create_shader_with_type(vertex_shader, fragment_shader, None, meta)
    }

    /// Create a compute shader
    #[cfg(feature = "vulkan")]
    pub fn create_compute_shader(&mut self, compute_shader: &str, meta: ShaderMeta) -> Result<usize, VulkanError> {
        self.create_shader_with_type("", "", Some(compute_shader), meta)
    }

    /// Create a shader with optional compute support
    #[cfg(feature = "vulkan")]
    fn create_shader_with_type(&mut self, vertex_shader: &str, fragment_shader: &str, compute_shader: Option<&str>, meta: ShaderMeta) -> Result<usize, VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        // Compile shaders
        let vertex_spv = if !vertex_shader.is_empty() {
            Some(self.compile_shader(vertex_shader, 0)?) // 0 = Vertex shader
        } else {
            None
        };
        
        let fragment_spv = if !fragment_shader.is_empty() {
            Some(self.compile_shader(fragment_shader, 1)?) // 1 = Fragment shader
        } else {
            None
        };
        
        let compute_spv = if let Some(cs) = compute_shader {
            Some(self.compile_shader(cs, 2)?) // 2 = Compute shader
        } else {
            None
        };
        
        // Create shader modules
        let vertex_module = if let Some(spv) = vertex_spv {
            let create_info = vk::ShaderModuleCreateInfo {
                p_code: spv.as_ptr(),
                code_size: spv.len(),
                ..Default::default()
            };
            
            Some(unsafe {
                device.create_shader_module(&create_info, None)
                    .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create vertex shader module: {}", e)))?
            })
        } else {
            None
        };
        
        let fragment_module = if let Some(spv) = fragment_spv {
            let create_info = vk::ShaderModuleCreateInfo {
                p_code: spv.as_ptr(),
                code_size: spv.len(),
                ..Default::default()
            };
            
            Some(unsafe {
                device.create_shader_module(&create_info, None)
                    .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create fragment shader module: {}", e)))?
            })
        } else {
            None
        };
        
        let compute_module = if let Some(spv) = compute_spv {
            let create_info = vk::ShaderModuleCreateInfo {
                p_code: spv.as_ptr(),
                code_size: spv.len(),
                ..Default::default()
            };
            
            Some(unsafe {
                device.create_shader_module(&create_info, None)
                    .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create compute shader module: {}", e)))?
            })
        } else {
            None
        };
        
        // Create descriptor set layout (simplified)
        let descriptor_set_layout = unsafe {
            device.create_descriptor_set_layout(&vk::DescriptorSetLayoutCreateInfo {
                ..Default::default()
            }, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create descriptor set layout: {}", e)))?
        };
        
        // Create pipeline layout
        let pipeline_layout = unsafe {
            device.create_pipeline_layout(&vk::PipelineLayoutCreateInfo {
                set_layout_count: 1,
                p_set_layouts: &descriptor_set_layout,
                ..Default::default()
            }, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create pipeline layout: {}", e)))?
        };
        
        let shader_id = self.shaders.len();
        let is_compute = compute_shader.is_some();
        
        self.shaders.push(VulkanShader {
            vertex_shader: vertex_module,
            fragment_shader: fragment_module,
            compute_shader: compute_module,
            descriptor_set_layout,
            pipeline_layout,
            uniform_blocks: vec![meta.uniforms],
            textures: meta.images,
            is_compute,
        });
        
        Ok(shader_id)
    }

    /// Create a graphics pipeline with custom configuration
    #[cfg(feature = "vulkan")]
    pub fn create_graphics_pipeline_with_config(
        &mut self, 
        shader_id: usize, 
        render_pass: vk::RenderPass,
        topology: vk::PrimitiveTopology,
        cull_mode: vk::CullModeFlags,
        blend_enable: bool,
        depth_test_enable: bool,
        depth_write_enable: bool
    ) -> Result<usize, VulkanError> {
        let device = self.device.as_ref().unwrap();
        let shader = &self.shaders[shader_id];
        
        // Create graphics pipeline with configurable parameters
        let vertex_input_state = vk::PipelineVertexInputStateCreateInfo {
            vertex_binding_description_count: 0,
            p_vertex_binding_descriptions: std::ptr::null(),
            vertex_attribute_description_count: 0,
            p_vertex_attribute_descriptions: std::ptr::null(),
            ..Default::default()
        };
        
        let input_assembly_state = vk::PipelineInputAssemblyStateCreateInfo {
            topology,
            primitive_restart_enable: vk::FALSE,
            ..Default::default()
        };
        
        // Use dynamic viewport and scissor for flexibility
        let viewport_state = vk::PipelineViewportStateCreateInfo {
            viewport_count: 1,
            p_viewports: std::ptr::null(), // Will be set dynamically
            scissor_count: 1,
            p_scissors: std::ptr::null(), // Will be set dynamically
            ..Default::default()
        };
        
        let rasterization_state = vk::PipelineRasterizationStateCreateInfo {
            depth_clamp_enable: vk::FALSE,
            rasterizer_discard_enable: vk::FALSE,
            polygon_mode: vk::PolygonMode::FILL,
            cull_mode,
            front_face: vk::FrontFace::CLOCKWISE,
            depth_bias_enable: vk::FALSE,
            depth_bias_constant_factor: 0.0,
            depth_bias_clamp: 0.0,
            depth_bias_slope_factor: 0.0,
            line_width: 1.0,
            ..Default::default()
        };
        
        let multisample_state = vk::PipelineMultisampleStateCreateInfo {
            sample_shading_enable: vk::TRUE,
            rasterization_samples: self.msaa_samples,
            min_sample_shading: 0.2,
            p_sample_mask: std::ptr::null(),
            alpha_to_coverage_enable: vk::TRUE,
            alpha_to_one_enable: vk::FALSE,
            ..Default::default()
        };
        
        // Configurable depth stencil state
        let depth_stencil_state = vk::PipelineDepthStencilStateCreateInfo {
            depth_test_enable: if depth_test_enable { vk::TRUE } else { vk::FALSE },
            depth_write_enable: if depth_write_enable { vk::TRUE } else { vk::FALSE },
            depth_compare_op: vk::CompareOp::LESS,
            depth_bounds_test_enable: vk::FALSE,
            min_depth_bounds: 0.0,
            max_depth_bounds: 1.0,
            stencil_test_enable: vk::FALSE,
            front: vk::StencilOpState {
                fail_op: vk::StencilOp::KEEP,
                pass_op: vk::StencilOp::KEEP,
                depth_fail_op: vk::StencilOp::KEEP,
                compare_op: vk::CompareOp::ALWAYS,
                compare_mask: 0,
                write_mask: 0,
                reference: 0,
            },
            back: vk::StencilOpState {
                fail_op: vk::StencilOp::KEEP,
                pass_op: vk::StencilOp::KEEP,
                depth_fail_op: vk::StencilOp::KEEP,
                compare_op: vk::CompareOp::ALWAYS,
                compare_mask: 0,
                write_mask: 0,
                reference: 0,
            },
            ..Default::default()
        };
        
        let color_blend_attachment = vk::PipelineColorBlendAttachmentState {
            color_write_mask: vk::ColorComponentFlags::R | vk::ColorComponentFlags::G | vk::ColorComponentFlags::B | vk::ColorComponentFlags::A,
            blend_enable: if blend_enable { vk::TRUE } else { vk::FALSE },
            src_color_blend_factor: vk::BlendFactor::SRC_ALPHA,
            dst_color_blend_factor: vk::BlendFactor::ONE_MINUS_SRC_ALPHA,
            color_blend_op: vk::BlendOp::ADD,
            src_alpha_blend_factor: vk::BlendFactor::ONE,
            dst_alpha_blend_factor: vk::BlendFactor::ZERO,
            alpha_blend_op: vk::BlendOp::ADD,
        };
        
        let color_blend_state = vk::PipelineColorBlendStateCreateInfo {
            logic_op_enable: vk::FALSE,
            logic_op: vk::LogicOp::COPY,
            attachment_count: 1,
            p_attachments: &color_blend_attachment,
            blend_constants: [0.0, 0.0, 0.0, 0.0],
            ..Default::default()
        };
        
        let shader_stages = [
            vk::PipelineShaderStageCreateInfo {
                stage: vk::ShaderStageFlags::VERTEX,
                module: shader.vertex_shader.unwrap(),
                p_name: unsafe { std::ffi::CStr::from_bytes_with_nul_unchecked(b"main\0").as_ptr() },
                ..Default::default()
            },
            vk::PipelineShaderStageCreateInfo {
                stage: vk::ShaderStageFlags::FRAGMENT,
                module: shader.fragment_shader.unwrap(),
                p_name: unsafe { std::ffi::CStr::from_bytes_with_nul_unchecked(b"main\0").as_ptr() },
                ..Default::default()
            },
        ];
        
        // Dynamic state for viewport and scissor
        let dynamic_states = [vk::DynamicState::VIEWPORT, vk::DynamicState::SCISSOR];
        let dynamic_state = vk::PipelineDynamicStateCreateInfo {
            s_type: vk::StructureType::PIPELINE_DYNAMIC_STATE_CREATE_INFO,
            p_next: std::ptr::null(),
            flags: vk::PipelineDynamicStateCreateFlags::empty(),
            dynamic_state_count: dynamic_states.len() as u32,
            p_dynamic_states: dynamic_states.as_ptr(),
            ..Default::default()
        };
        
        let pipeline_create_info = vk::GraphicsPipelineCreateInfo {
            s_type: vk::StructureType::GRAPHICS_PIPELINE_CREATE_INFO,
            p_next: std::ptr::null(),
            flags: vk::PipelineCreateFlags::empty(),
            stage_count: shader_stages.len() as u32,
            p_stages: shader_stages.as_ptr(),
            p_vertex_input_state: &vertex_input_state,
            p_input_assembly_state: &input_assembly_state,
            p_viewport_state: &viewport_state,
            p_rasterization_state: &rasterization_state,
            p_multisample_state: &multisample_state,
            p_depth_stencil_state: &depth_stencil_state,
            p_color_blend_state: &color_blend_state,
            p_dynamic_state: &dynamic_state,
            layout: shader.pipeline_layout,
            render_pass,
            subpass: 0,
            base_pipeline_handle: vk::Pipeline::null(),
            base_pipeline_index: 0,
            ..Default::default()
        };
        
        let graphics_pipeline = unsafe {
            device.create_graphics_pipelines(vk::PipelineCache::null(), &[pipeline_create_info], None)
                .map_err(|(_, e)| VulkanError::PipelineCreationFailed(format!("Failed to create graphics pipeline: {}", e)))?[0]
        };
        
        let pipeline_id = self.pipelines.len();
        
        self.pipelines.push(VulkanPipeline {
            pipeline: graphics_pipeline,
            layout: shader.pipeline_layout,
            shader_id,
            vertex_attributes: Vec::new(), // Would need proper vertex attribute description
            params: PipelineParams::default(),
            is_compute: false,
        });
        
        Ok(pipeline_id)
    }

    /// Create a basic graphics pipeline (legacy method for compatibility)
    #[cfg(feature = "vulkan")]
    pub fn create_graphics_pipeline(&mut self, shader_id: usize, render_pass: vk::RenderPass) -> Result<usize, VulkanError> {
        self.create_graphics_pipeline_with_config(
            shader_id,
            render_pass,
            vk::PrimitiveTopology::TRIANGLE_LIST,
            vk::CullModeFlags::BACK,
            true,  // blend_enable
            true,  // depth_test_enable
            true   // depth_write_enable
        )
    }

    /// Create a compute pipeline
    #[cfg(feature = "vulkan")]
    pub fn create_compute_pipeline(&mut self, shader_id: usize) -> Result<usize, VulkanError> {
        let device = self.device.as_ref().unwrap();
        let shader = &self.shaders[shader_id];
        
        if shader.compute_shader.is_none() {
            return Err(VulkanError::InitializationFailed("Shader does not contain compute module".to_string()));
        }
        
        // Create compute pipeline layout
        let pipeline_layout = unsafe {
            device.create_pipeline_layout(&vk::PipelineLayoutCreateInfo {
                set_layout_count: 1,
                p_set_layouts: &shader.descriptor_set_layout,
                ..Default::default()
            }, None)
                .map_err(|e| VulkanError::PipelineCreationFailed(format!("Failed to create compute pipeline layout: {}", e)))?
        };
        
        // Create compute pipeline
        let shader_stage = vk::PipelineShaderStageCreateInfo {
            stage: vk::ShaderStageFlags::COMPUTE,
            module: shader.compute_shader.unwrap(),
            p_name: unsafe { std::ffi::CStr::from_bytes_with_nul_unchecked(b"main\0").as_ptr() },
            ..Default::default()
        };
        
        let pipeline_create_info = vk::ComputePipelineCreateInfo {
            stage: shader_stage,
            layout: pipeline_layout,
            ..Default::default()
        };
        
        let compute_pipeline = unsafe {
            device.create_compute_pipelines(vk::PipelineCache::null(), &[pipeline_create_info], None)
                .map_err(|(_, e)| VulkanError::PipelineCreationFailed(format!("Failed to create compute pipeline: {}", e)))?[0]
        };
        
        let pipeline_id = self.pipelines.len();
        
        self.pipelines.push(VulkanPipeline {
            pipeline: compute_pipeline,
            layout: pipeline_layout,
            shader_id,
            vertex_attributes: Vec::new(),
            params: PipelineParams::default(),
            is_compute: true,
        });
        
        Ok(pipeline_id)
    }

    #[cfg(feature = "vulkan")]
    fn compile_shader(&self, source: &str, _kind: u32) -> Result<Vec<u32>, VulkanError> {
        // Placeholder implementation - in real implementation would use shaderc
        // For now, return a simple SPIR-V binary that just does basic operations
        
        // Generate a simple SPIR-V binary based on shader type
        let shader_type = match _kind {
            0 => "vertex",   // Vertex shader
            1 => "fragment", // Fragment shader  
            2 => "compute",  // Compute shader
            _ => "unknown",
        };
        
        // Create a minimal SPIR-V module header
        let mut spirv = vec![
            0x07230203u32, // Magic number
            0x00010000u32, // Version 1.0
            0x00000000u32, // Generator ID
            0x00000000u32, // Bound
            0x00000000u32, // Schema
        ];
        
        // Add basic capability and memory model instructions
        spirv.extend_from_slice(&[0x00010000u32, 0x00000000u32]); // OpCapability - CapabilityShader
        spirv.extend_from_slice(&[0x00050000u32, 0x00000002u32, 0x00000000u32]); // OpMemoryModel
        
        // Add basic function and type instructions
        spirv.extend_from_slice(&[0x00020000u32, 0x0000000cu32, 0x00000001u32]); // OpTypeVoid
        spirv.extend_from_slice(&[0x00020000u32, 0x0000000du32, 0x0000000cu32]); // OpTypeFunction
        
        // Add entry point declaration
        let entry_point_instr = format!("OpEntryPoint GLES 0 main \"main\"");
        spirv.extend_from_slice(&[0x00030000u32, 0x00000007u32, 0x00000000u32]); // OpFunction
        
        // Add main function
        spirv.extend_from_slice(&[0x00020000u32, 0x0000000eu32, 0x0000000cu32]); // OpTypeInt
        spirv.extend_from_slice(&[0x00040000u32, 0x0000000fu32, 0x0000000eu32, 0x00000001u32, 0x00000000u32]); // OpConstant
        
        // Add return instruction
        spirv.extend_from_slice(&[0x00030000u32, 0x00000010u32, 0x0000000cu32]); // OpReturn
        spirv.extend_from_slice(&[0x00000000u32]); // OpFunctionEnd
        
        println!("Placeholder shader compilation for {} shader", shader_type);
        println!("Shader source (first 100 chars): {}", &source[..std::cmp::min(source.len(), 100)]);
        
        Ok(spirv)
    }

    

