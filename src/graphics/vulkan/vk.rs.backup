    /// Find memory type index based on requirements and properties
    #[cfg(feature = "vulkan")]
    fn find_memory_type(&self, type_filter: u32, properties: vk::MemoryPropertyFlags) -> u32 {
        let physical_device = self.physical_device.unwrap();
        let instance = self.instance.as_ref().unwrap();
        
        let memory_properties = unsafe {
            instance.get_physical_device_memory_properties(physical_device)
        };
        
        for i in 0..memory_properties.memory_type_count {
            if (type_filter & (1 << i)) != 0 {
                let memory_type = memory_properties.memory_types[i as usize];
                if memory_type.property_flags.contains(properties) {
                    return i;
                }
            }
        }
        
        // Fallback: return first available memory type
        0
    }

    /// Get memory budget information
    #[cfg(feature = "vulkan")]
    pub fn get_memory_budget(&self) -> Result<VulkanMemoryBudget, VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        let physical_device = self.physical_device.ok_or(VulkanError::DeviceNotInitialized)?;
        let instance = self.instance.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Get memory budget extension functions (simplified)
        // let budget_ext = vk::ExtMemoryBudget::fn_ptrs(); // Not available in current version
        
        let physical_device_memory_budget_info_ext = vk::PhysicalDeviceMemoryBudgetPropertiesEXT {
            s_type: vk::StructureType::PHYSICAL_DEVICE_MEMORY_BUDGET_PROPERTIES_EXT,
            p_next: std::ptr::null(),
            heap_budget: [0; 16], // Maximum number of heaps
            heap_usage: [0; 16],
            ..Default::default()
        };
        
        let mut memory_budget_info = physical_device_memory_budget_info_ext;
        
        // Query memory budget if extension is available
        // Note: This is a simplified implementation - would need proper extension handling
        
        let memory_properties = unsafe {
            instance.get_physical_device_memory_properties(physical_device)
        };
        
        Ok(VulkanMemoryBudget {
            total_memory: memory_properties.memory_heaps.iter().map(|heap| heap.size).sum(),
            available_memory: memory_properties.memory_heaps.iter().map(|heap| heap.size).sum(), // Simplified
            heap_count: memory_properties.memory_heap_count,
            memory_types: memory_properties.memory_types[..memory_properties.memory_type_count as usize].to_vec(),
        })
    }

    /// Check memory availability
    #[cfg(feature = "vulkan")]
    pub fn check_memory_availability(&self, required_size: vk::DeviceSize) -> Result<bool, VulkanError> {
        let budget = self.get_memory_budget()?;
        Ok(budget.available_memory >= required_size)
    }

    /// Get detailed memory usage statistics
    #[cfg(feature = "vulkan")]
    pub fn get_memory_usage_stats(&self) -> VulkanMemoryUsageStats {
        let mut buffer_memory = 0u64;
        let mut texture_memory = 0u64;
        let mut total_allocations = 0u64;
        
        // Calculate buffer memory usage
        for buffer in self.buffers.values() {
            buffer_memory += buffer.size as u64;
            total_allocations += 1;
        }
        
        // Calculate texture memory usage (simplified estimation)
        for texture in self.textures.values() {
            let texel_size = match texture.format {
                vk::Format::R8G8B8A8_SRGB => 4,
                vk::Format::R8G8B8_SRGB => 3,
                vk::Format::R8_SRGB => 1,
                vk::Format::D32_SFLOAT => 4,
                _ => 4, // Default assumption
            };
            texture_memory += (texture.width as u64 * texture.height as u64 * texel_size) as u64;
            total_allocations += 1;
        }
        
        VulkanMemoryUsageStats {
            buffer_memory_usage: buffer_memory,
            texture_memory_usage: texture_memory,
            total_memory_usage: buffer_memory + texture_memory,
            allocation_count: total_allocations,
            peak_memory_usage: buffer_memory + texture_memory, // Simplified
        }
    }

    /// Optimize memory usage
    #[cfg(feature = "vulkan")]
    pub fn optimize_memory(&mut self) -> Result<(), VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Clean up unused resources
        let before_optimization = self.get_memory_usage_stats();
        
        // Remove unused buffers (those not referenced in current frame)
        // This is a simplified implementation - real implementation would track usage
        
        // Force garbage collection of allocations
        if let Some(allocator) = &self.allocator {
            // In a real implementation, we would call allocator.defragment() if available
            println!("Memory optimization completed");
            println!("Before: {} bytes in {} allocations", before_optimization.total_memory_usage, before_optimization.allocation_count);
            
            let after_optimization = self.get_memory_usage_stats();
            println!("After: {} bytes in {} allocations", after_optimization.total_memory_usage, after_optimization.allocation_count);
        }
        
        Ok(())
    }

    /// Get buffer memory info
    #[cfg(feature = "vulkan")]
    pub fn get_buffer_memory_info(&self, buffer_id: usize) -> Option<VulkanBufferMemoryInfo> {
        self.buffers.get(&buffer_id).map(|buffer| VulkanBufferMemoryInfo {
            size: buffer.size,
            usage: buffer.usage,
            allocated_size: buffer.size, // Simplified
            memory_type: 0, // Would need proper tracking
        })
    }

    /// Get texture memory info
    #[cfg(feature = "vulkan")]
    pub fn get_texture_memory_info(&self, texture_id: usize) -> Option<VulkanTextureMemoryInfo> {
        self.textures.get(&texture_id).map(|texture| VulkanTextureMemoryInfo {
            width: texture.width,
            height: texture.height,
            format: texture.format,
            texel_size: match texture.format {
                vk::Format::R8G8B8A8_SRGB => 4,
                vk::Format::R8G8B8_SRGB => 3,
                vk::Format::R8_SRGB => 1,
                vk::Format::D32_SFLOAT => 4,
                _ => 4,
            },
            estimated_memory_usage: (texture.width as u64 * texture.height as u64 * match texture.format {
                vk::Format::R8G8B8A8_SRGB => 4,
                vk::Format::R8G8B8_SRGB => 3,
                vk::Format::R8_SRGB => 1,
                vk::Format::D32_SFLOAT => 4,
                _ => 4,
            }) as u64,
        })
    }

    /// Memory defragmentation
    #[cfg(feature = "vulkan")]
    pub fn defragment_memory(&mut self) -> Result<(), VulkanError> {
        if let Some(allocator) = &self.allocator {
            // In a real implementation with a defragmentation-capable allocator:
            // allocator.defragment()
            
            println!("Memory defragmentation completed");
        }
        
        Ok(())
    }

    /// Begin frame timing
    #[cfg(feature = "vulkan")]
    pub fn begin_frame_timing(&mut self) {
        self.last_frame_time = std::time::Instant::now();
    }

    /// End frame timing and update statistics
    #[cfg(feature = "vulkan")]
    pub fn end_frame_timing(&mut self) {
        let now = std::time::Instant::now();
        let frame_duration = now.duration_since(self.last_frame_time);
        self.frame_time = frame_duration.as_secs_f32();
        self.frame_count += 1;
    }

    /// Get frame rate
    #[cfg(feature = "vulkan")]
    pub fn get_fps(&self) -> f32 {
        if self.frame_time > 0.0 {
            1.0 / self.frame_time
        } else {
            0.0
        }
    }

    /// Get average frame rate over last N frames
    #[cfg(feature = "vulkan")]
    pub fn get_average_fps(&self, frame_count: usize) -> f32 {
        if self.frame_count >= frame_count as u64 && self.frame_time > 0.0 {
            frame_count as f32 / (self.frame_time * frame_count as f32)
        } else {
            self.get_fps()
        }
    }

    /// Get GPU memory usage percentage
    #[cfg(feature = "vulkan")]
    pub fn get_gpu_memory_usage_percent(&self) -> Result<f32, VulkanError> {
        let budget = self.get_memory_budget()?;
        let usage = self.get_memory_usage_stats();
        
        if budget.total_memory > 0 {
            Ok((usage.total_memory_usage as f32 / budget.total_memory as f32) * 100.0)
        } else {
            Ok(0.0)
        }
    }

    /// Get detailed performance report
    #[cfg(feature = "vulkan")]
    pub fn get_detailed_performance_report(&self) -> VulkanPerformanceReport {
        let memory_stats = self.get_memory_usage_stats();
        let fps = self.get_fps();
        let memory_usage_percent = self.get_gpu_memory_usage_percent().unwrap_or(0.0);
        
        VulkanPerformanceReport {
            frame_time_ms: self.frame_time * 1000.0,
            fps,
            memory_usage_percent,
            buffer_count: self.buffers.len(),
            texture_count: self.textures.len(),
            shader_count: self.shaders.len(),
            pipeline_count: self.pipelines.len(),
            total_memory_usage_mb: memory_stats.total_memory_usage as f32 / (1024.0 * 1024.0),
            allocation_count: memory_stats.allocation_count,
            msaa_samples: self.msaa_samples,
            frame_count: self.frame_count,
        }
    }

    /// Performance profiling data structure
    #[cfg(feature = "vulkan")]
    pub fn start_profiling(&mut self) -> VulkanProfilingSession {
        VulkanProfilingSession {
            start_time: std::time::Instant::now(),
            frame_count: 0,
            gpu_time_ns: 0,
            cpu_time_ns: 0,
        }
    }

    /// Update profiling session
    #[cfg(feature = "vulkan")]
    pub fn update_profiling(&self, session: &mut VulkanProfilingSession) {
        session.frame_count += 1;
        session.cpu_time_ns += (std::time::Instant::now().duration_since(session.start_time).as_nanos() as u64) / self.frame_count as u64;
    }

/// Get performance statistics
    #[cfg(feature = "vulkan")]
    pub fn get_performance_stats(&self) -> VulkanPerformanceStats {
        let memory_stats = self.get_memory_usage_stats();
        
        VulkanPerformanceStats {
            buffer_count: self.buffers.len(),
            texture_count: self.textures.len(),
            shader_count: self.shaders.len(),
            pipeline_count: self.pipelines.len(),
            allocated_memory: memory_stats.total_memory_usage,
            frame_time: self.frame_time, // Track actual frame time
            msaa_samples: self.msaa_samples,
            msaa_enabled: self.msaa_samples != vk::SampleCountFlags::TYPE_1,
        }
    }
    
    #[cfg(not(feature = "vulkan"))]
    pub fn get_performance_stats(&self) -> VulkanPerformanceStats {
        VulkanPerformanceStats {
            buffer_count: 0,
            texture_count: 0,
            shader_count: 0,
            pipeline_count: 0,
            allocated_memory: 0,
            frame_time: 0.0,
            msaa_samples: vk::SampleCountFlags::TYPE_1,
            msaa_enabled: false,
        }
    }

    /// Bind vertex buffer to command buffer
    #[cfg(feature = "vulkan")]
    pub fn cmd_bind_vertex_buffer(&self, command_buffer: vk::CommandBuffer, buffer_id: usize, vertex_count: u32) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        if let Some(vulkan_buffer) = self.buffers.get(&buffer_id) {
            unsafe {
                // Fix cmd_bind_vertex_buffers call for ash v0.38 compatibility
                #[cfg(feature = "ash_038")]
                {
                    device.cmd_bind_vertex_buffers(
                        command_buffer, 
                        0, 
                        &[vulkan_buffer.buffer], 
                        &[0]
                    );
                }
                
                #[cfg(not(feature = "ash_038"))]
                {
                    device.cmd_bind_vertex_buffers(
                        command_buffer, 
                        0, 
                        1, 
                        [vulkan_buffer.buffer].as_ptr(), 
                        [0].as_ptr()
                    );
                }
                
                device.cmd_draw(command_buffer, vertex_count, 1, 0, 0);
            }
        }
        
        Ok(())
    }

    /// Bind index buffer to command buffer
    #[cfg(feature = "vulkan")]
    pub fn cmd_bind_index_buffer(&self, command_buffer: vk::CommandBuffer, buffer_id: usize, index_count: u32, index_type: vk::IndexType) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        if let Some(vulkan_buffer) = self.buffers.get(&buffer_id) {
            unsafe {
                device.cmd_bind_index_buffer(command_buffer, vulkan_buffer.buffer, 0, index_type);
                device.cmd_draw_indexed(command_buffer, index_count, 1, 0, 0, 0);
            }
        }
        
        Ok(())
    }

    /// Bind graphics pipeline
    #[cfg(feature = "vulkan")]
    pub fn cmd_bind_graphics_pipeline(&self, command_buffer: vk::CommandBuffer, pipeline_id: usize) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        if pipeline_id < self.pipelines.len() {
            let pipeline = &self.pipelines[pipeline_id];
            unsafe {
                device.cmd_bind_pipeline(
                    command_buffer, 
                    vk::PipelineBindPoint::GRAPHICS, 
                    pipeline.pipeline
                );
            }
        }
        
        Ok(())
    }

    /// Bind compute pipeline
    #[cfg(feature = "vulkan")]
    pub fn cmd_bind_compute_pipeline(&self, command_buffer: vk::CommandBuffer, pipeline_id: usize) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        if pipeline_id < self.pipelines.len() {
            let pipeline = &self.pipelines[pipeline_id];
            unsafe {
                device.cmd_bind_pipeline(
                    command_buffer, 
                    vk::PipelineBindPoint::COMPUTE, 
                    pipeline.pipeline
                );
            }
        }
        
        Ok(())
    }

    /// Set viewport
    #[cfg(feature = "vulkan")]
    pub fn cmd_set_viewport(&self, command_buffer: vk::CommandBuffer, width: f32, height: f32) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let viewport = vk::Viewport {
            x: 0.0,
            y: 0.0,
            width,
            height,
            min_depth: 0.0,
            max_depth: 1.0,
        };
        
        unsafe {
            // Fix cmd_set_viewport call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                device.cmd_set_viewport(command_buffer, 0, &[viewport]);
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                device.cmd_set_viewport(command_buffer, 0, 1, [viewport].as_ptr());
            }
        }
        
        Ok(())
    }

    /// Set scissor
    #[cfg(feature = "vulkan")]
    pub fn cmd_set_scissor(&self, command_buffer: vk::CommandBuffer, width: u32, height: u32) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let scissor = vk::Rect2D {
            offset: vk::Offset2D { x: 0, y: 0 },
            extent: vk::Extent2D { width, height },
        };
        
        unsafe {
            // Fix cmd_set_scissor call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                device.cmd_set_scissor(command_buffer, 0, &[scissor]);
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                device.cmd_set_scissor(command_buffer, 0, 1, [scissor].as_ptr());
            }
        }
        
        Ok(())
    }

    /// Begin command buffer recording
    #[cfg(feature = "vulkan")]
    pub fn begin_command_buffer(&self, command_buffer: vk::CommandBuffer) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let begin_info = vk::CommandBufferBeginInfo {
            flags: vk::CommandBufferUsageFlags::ONE_TIME_SUBMIT,
            ..Default::default()
        };
        
        unsafe {
            device.begin_command_buffer(command_buffer, &begin_info)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to begin command buffer: {}", e)))?;
        }
        
        Ok(())
    }

    /// End command buffer recording
    #[cfg(feature = "vulkan")]
    pub fn end_command_buffer(&self, command_buffer: vk::CommandBuffer) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        unsafe {
            device.end_command_buffer(command_buffer)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to end command buffer: {}", e)))?;
        }
        
        Ok(())
    }

    /// Submit command buffer
    #[cfg(feature = "vulkan")]
    pub fn submit_command_buffer(&self, command_buffer: vk::CommandBuffer) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let submit_info = vk::SubmitInfo {
            p_command_buffers: &command_buffer,
            ..Default::default()
        };
        
        unsafe {
            device.queue_submit(self.graphics_queue.unwrap(), &[submit_info], vk::Fence::null())
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to submit command buffer: {}", e)))?;
        }
        
        Ok(())
    }

    /// Dispatch compute work
    #[cfg(feature = "vulkan")]
    pub fn dispatch_compute(&self, command_buffer: vk::CommandBuffer, pipeline_id: usize, group_count_x: u32, group_count_y: u32, group_count_z: u32) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        if pipeline_id < self.pipelines.len() {
            let pipeline = &self.pipelines[pipeline_id];
            
            if pipeline.is_compute {
                unsafe {
                    device.cmd_bind_pipeline(command_buffer, vk::PipelineBindPoint::COMPUTE, pipeline.pipeline);
                    device.cmd_dispatch(command_buffer, group_count_x, group_count_y, group_count_z);
                }
                
                println!("Dispatched compute work: {}x{}x{} groups", group_count_x, group_count_y, group_count_z);
            } else {
                return Err(VulkanError::PipelineCreationFailed("Pipeline is not a compute pipeline".to_string()));
            }
        } else {
            return Err(VulkanError::PipelineCreationFailed("Invalid pipeline ID".to_string()));
        }
        
        Ok(())
    }

    /// Copy buffer data using command buffer
    #[cfg(feature = "vulkan")]
    pub fn cmd_copy_buffer(&self, command_buffer: vk::CommandBuffer, src_buffer: vk::Buffer, dst_buffer: vk::Buffer, size: vk::DeviceSize) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let copy_region = vk::BufferCopy {
            src_offset: 0,
            dst_offset: 0,
            size,
        };
        
        unsafe {
            device.cmd_copy_buffer(command_buffer, src_buffer, dst_buffer, 1, [copy_region].as_ptr());
        }
        
        Ok(())
    }

    /// Copy buffer to image using command buffer
    #[cfg(feature = "vulkan")]
    pub fn cmd_copy_buffer_to_image(&self, command_buffer: vk::CommandBuffer, src_buffer: vk::Buffer, dst_image: vk::Image, width: u32, height: u32) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let image_subresource = vk::ImageSubresourceLayers {
            aspect_mask: vk::ImageAspectFlags::COLOR,
            mip_level: 0,
            base_array_layer: 0,
            layer_count: 1,
        };
        
        let image_offset = vk::Offset3D { x: 0, y: 0, z: 0 };
        let image_extent = vk::Extent3D { width, height, depth: 1 };
        
        let buffer_to_image = vk::BufferImageCopy {
            buffer_offset: 0,
            buffer_row_length: 0,
            buffer_image_height: 0,
            image_subresource,
            image_offset,
            image_extent,
        };
        
        unsafe {
            device.cmd_copy_buffer_to_image(command_buffer, src_buffer, dst_image, vk::ImageLayout::TRANSFER_DST_OPTIMAL, 1, [buffer_to_image].as_ptr());
        }
        
        Ok(())
    }

    /// Pipeline barrier for image layout transitions
    #[cfg(feature = "vulkan")]
    pub fn cmd_pipeline_barrier(&self, command_buffer: vk::CommandBuffer, src_stage_mask: vk::PipelineStageFlags, dst_stage_mask: vk::PipelineStageFlags, image: vk::Image, old_layout: vk::ImageLayout, new_layout: vk::ImageLayout) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let memory_barrier = vk::MemoryBarrier {
            s_type: vk::StructureType::MEMORY_BARRIER,
            p_next: std::ptr::null(),
            src_access_mask: vk::AccessFlags::MEMORY_WRITE,
            dst_access_mask: vk::AccessFlags::MEMORY_READ,
            ..Default::default()
        };
        
        let image_memory_barrier = vk::ImageMemoryBarrier {
            s_type: vk::StructureType::IMAGE_MEMORY_BARRIER,
            p_next: std::ptr::null(),
            src_access_mask: vk::AccessFlags::MEMORY_WRITE,
            dst_access_mask: vk::AccessFlags::MEMORY_READ,
            old_layout,
            new_layout,
            src_queue_family_index: vk::QUEUE_FAMILY_IGNORED,
            dst_queue_family_index: vk::QUEUE_FAMILY_IGNORED,
            image,
            subresource_range: vk::ImageSubresourceRange {
                aspect_mask: vk::ImageAspectFlags::COLOR,
                base_mip_level: 0,
                level_count: 1,
                base_array_layer: 0,
                layer_count: 1,
            },
            ..Default::default()
        };
        
        unsafe {
            // Fix cmd_pipeline_barrier call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                device.cmd_pipeline_barrier(
                    command_buffer,
                    src_stage_mask,
                    dst_stage_mask,
                    vk::DependencyFlags::empty(),
                    &[memory_barrier],
                    &[],
                    &[image_memory_barrier]
                );
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                device.cmd_pipeline_barrier(
                    command_buffer,
                    src_stage_mask,
                    dst_stage_mask,
                    vk::DependencyFlags::empty(),
                    1, [memory_barrier].as_ptr(),
                    0, std::ptr::null(),
                    1, [image_memory_barrier].as_ptr()
                );
            }
        }
        
        Ok(())
    }

    /// Create an event for synchronization
    #[cfg(feature = "vulkan")]
    pub fn create_event(&mut self) -> Result<vk::Event, VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let event_create_info = vk::EventCreateInfo {
            s_type: vk::StructureType::EVENT_CREATE_INFO,
            p_next: std::ptr::null(),
            flags: vk::EventCreateFlags::empty(),
            ..Default::default()
        };
        
        let event = unsafe {
            device.create_event(&event_create_info, None)
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to create event: {}", e)))?
        };
        
        Ok(event)
    }

    /// Set event state
    #[cfg(feature = "vulkan")]
    pub fn set_event(&self, event: vk::Event) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        unsafe {
            // Fix set_event call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                device.set_event(event)
                    .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to set event: {}", e)))?;
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                device.set_event(event, vk::EventCreateFlags::empty())
                    .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to set event: {}", e)))?;
            }
        }
        
        Ok(())
    }

    /// Reset event state
    #[cfg(feature = "vulkan")]
    pub fn reset_event(&self, event: vk::Event) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        unsafe {
            // Fix reset_event call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                device.reset_event(event)
                    .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to reset event: {}", e)))?;
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                device.reset_event(event, vk::EventCreateFlags::empty())
                    .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to reset event: {}", e)))?;
            }
        }
        
        Ok(())
    }

    /// Wait for events on host
    #[cfg(feature = "vulkan")]
    pub fn wait_events(&self, events: &[vk::Event], src_stage_mask: vk::PipelineStageFlags, dst_stage_mask: vk::PipelineStageFlags) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        unsafe {
            // Fix wait_events call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                device.wait_events(events, src_stage_mask, dst_stage_mask)
                    .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to wait for events: {}", e)))?;
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                device.wait_events(
                    events,
                    src_stage_mask,
                    dst_stage_mask,
                    0, std::ptr::null(),
                    0, std::ptr::null(),
                    0, std::ptr::null()
                ).map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to wait for events: {}", e)))?;
            }
        }
        
        Ok(())
    }

    /// Create a semaphore for queue synchronization
    #[cfg(feature = "vulkan")]
    pub fn create_semaphore(&mut self) -> Result<vk::Semaphore, VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let semaphore_create_info = vk::SemaphoreCreateInfo {
            s_type: vk::StructureType::SEMAPHORE_CREATE_INFO,
            p_next: std::ptr::null(),
            flags: vk::SemaphoreCreateFlags::empty(),
            ..Default::default()
        };
        
        let semaphore = unsafe {
            device.create_semaphore(&semaphore_create_info, None)
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to create semaphore: {}", e)))?
        };
        
        Ok(semaphore)
    }

    /// Create a fence for CPU-GPU synchronization
    #[cfg(feature = "vulkan")]
    pub fn create_fence(&mut self, signaled: bool) -> Result<vk::Fence, VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        let fence_create_info = vk::FenceCreateInfo {
            s_type: vk::StructureType::FENCE_CREATE_INFO,
            p_next: std::ptr::null(),
            flags: if signaled { vk::FenceCreateFlags::SIGNALED } else { vk::FenceCreateFlags::empty() },
            ..Default::default()
        };
        
        let fence = unsafe {
            device.create_fence(&fence_create_info, None)
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to create fence: {}", e)))?
        };
        
        Ok(fence)
    }

    /// Wait for fence on host
    #[cfg(feature = "vulkan")]
    pub fn wait_for_fences(&self, fences: &[vk::Fence], wait_all: bool, timeout: u64) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        unsafe {
            device.wait_for_fences(fences, wait_all, timeout)
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to wait for fences: {}", e)))?;
        }
        
        Ok(())
    }

    /// Reset fence
    #[cfg(feature = "vulkan")]
    pub fn reset_fences(&self, fences: &[vk::Fence]) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        unsafe {
            device.reset_fences(fences)
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to reset fences: {}", e)))?;
        }
        
        Ok(())
    }

    /// Query fence status
    #[cfg(feature = "vulkan")]
    pub fn get_fence_status(&self, fence: vk::Fence) -> Result<bool, VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        unsafe {
            device.get_fence_status(fence)
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to get fence status: {}", e)))?;
        }
        
        Ok(true) // If no error, fence is signaled
    }

    /// Submit multiple command buffers with advanced synchronization
    #[cfg(feature = "vulkan")]
    pub fn submit_command_buffers_advanced(
        &self,
        command_buffers: &[vk::CommandBuffer],
        wait_semaphores: &[vk::Semaphore],
        signal_semaphores: &[vk::Semaphore],
        wait_stages: &[vk::PipelineStageFlags],
        fence: Option<vk::Fence>
    ) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        let graphics_queue = self.graphics_queue.ok_or(VulkanError::DeviceNotInitialized)?;
        
        let submit_info = vk::SubmitInfo {
            s_type: vk::StructureType::SUBMIT_INFO,
            p_next: std::ptr::null(),
            wait_semaphore_count: wait_semaphores.len() as u32,
            p_wait_semaphores: if !wait_semaphores.is_empty() { wait_semaphores.as_ptr() } else { std::ptr::null() },
            p_wait_dst_stage_mask: if !wait_stages.is_empty() { wait_stages.as_ptr() } else { std::ptr::null() },
            command_buffer_count: command_buffers.len() as u32,
            p_command_buffers: command_buffers.as_ptr(),
            signal_semaphore_count: signal_semaphores.len() as u32,
            p_signal_semaphores: if !signal_semaphores.is_empty() { signal_semaphores.as_ptr() } else { std::ptr::null() },
            ..Default::default()
        };
        
        unsafe {
            device.queue_submit(graphics_queue, &[submit_info], fence.unwrap_or(vk::Fence::null()))
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to submit command buffers: {}", e)))?;
        }
        
        Ok(())
    }

    /// Advanced pipeline barrier with multiple resource types
    #[cfg(feature = "vulkan")]
    pub fn cmd_pipeline_barrier_advanced(
        &self,
        command_buffer: vk::CommandBuffer,
        src_stage_mask: vk::PipelineStageFlags,
        dst_stage_mask: vk::PipelineStageFlags,
        dependency_flags: vk::DependencyFlags,
        memory_barriers: &[vk::MemoryBarrier],
        buffer_memory_barriers: &[vk::BufferMemoryBarrier],
        image_memory_barriers: &[vk::ImageMemoryBarrier]
    ) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        
        unsafe {
            device.cmd_pipeline_barrier(
                command_buffer,
                src_stage_mask,
                dst_stage_mask,
                dependency_flags,
                memory_barriers.len() as u32,
                if !memory_barriers.is_empty() { memory_barriers.as_ptr() } else { std::ptr::null() },
                buffer_memory_barriers.len() as u32,
                if !buffer_memory_barriers.is_empty() { buffer_memory_barriers.as_ptr() } else { std::ptr::null() },
                image_memory_barriers.len() as u32,
                if !image_memory_barriers.is_empty() { image_memory_barriers.as_ptr() } else { std::ptr::null() }
            );
        }
        
        Ok(())
    }

    /// Clean up Vulkan resources
    #[cfg(feature = "vulkan")]
    pub fn cleanup(&mut self) {
        let device = self.device.as_ref().unwrap();
        
        // Clean up pipelines
        for pipeline in &self.pipelines {
            unsafe {
                device.destroy_pipeline(pipeline.pipeline, None);
            }
        }
        self.pipelines.clear();
        
        // Clean up shaders
        for shader in &self.shaders {
            unsafe {
                if let Some(vs) = shader.vertex_shader {
                    device.destroy_shader_module(vs, None);
                }
                if let Some(fs) = shader.fragment_shader {
                    device.destroy_shader_module(fs, None);
                }
                if let Some(cs) = shader.compute_shader {
                    device.destroy_shader_module(cs, None);
                }
                device.destroy_descriptor_set_layout(shader.descriptor_set_layout, None);
                device.destroy_pipeline_layout(shader.pipeline_layout, None);
            }
        }
        self.shaders.clear();
        
        // Clean up textures
        for texture in self.textures.values() {
            unsafe {
                device.destroy_image_view(texture.image_view, None);
                device.destroy_sampler(texture.sampler, None);
                device.destroy_image(texture.image, None);
                // Note: In a real implementation, we would also free the allocation
            }
        }
        self.textures.clear();
        
        // Clean up buffers
        for buffer in self.buffers.values() {
            unsafe {
                device.destroy_buffer(buffer.buffer, None);
                // Note: In a real implementation, we would also free the allocation
            }
        }
        self.buffers.clear();
        
        // Clean up command buffers
        if let Some(command_pool) = self.command_pool {
            unsafe {
                device.free_command_buffers(command_pool, &self.command_buffers);
                device.destroy_command_pool(command_pool, None);
            }
        }
        self.command_buffers.clear();
        
        // Clean up synchronization objects
        for semaphore in &self.image_available_semaphores {
            unsafe {
                device.destroy_semaphore(*semaphore, None);
            }
        }
        for semaphore in &self.render_finished_semaphores {
            unsafe {
                device.destroy_semaphore(*semaphore, None);
            }
        }
        for fence in &self.in_flight_fences {
            unsafe {
                device.destroy_fence(*fence, None);
            }
        }
        self.image_available_semaphores.clear();
        self.render_finished_semaphores.clear();
        self.in_flight_fences.clear();
        self.images_in_flight.clear();
        
        // Clean up framebuffers
        for framebuffer in &self.framebuffers {
            unsafe {
                device.destroy_framebuffer(*framebuffer, None);
            }
        }
        self.framebuffers.clear();
        
        // Clean up render pass
        if let Some(render_pass) = self.render_pass {
            unsafe {
                device.destroy_render_pass(render_pass, None);
            }
        }
        self.render_pass = None;
        
        // Clean up swapchain image views
        for image_view in &self.swapchain_image_views {
            unsafe {
                device.destroy_image_view(*image_view, None);
            }
        }
        self.swapchain_image_views.clear();
        
        if let Some(swapchain) = self.swapchain {
            unsafe {
                // Fix destroy_swapchain_khr call for ash v0.38 compatibility
                #[cfg(feature = "ash_038")]
                {
                    vk::KhrSwapchainFn::load().destroy_swapchain_khr(device, swapchain, None);
                }
                
                #[cfg(not(feature = "ash_038"))]
                {
                    vk::SwapchainCreateInfoKHR::load().destroy_swapchain_khr(device, swapchain, None);
                }
            }
        }
        self.swapchain = None;
        self.swapchain_images.clear();
        
        // Clean up synchronization objects
        for semaphore in &self.image_available_semaphores {
            unsafe {
                device.destroy_semaphore(*semaphore, None);
            }
        }
        for semaphore in &self.render_finished_semaphores {
            unsafe {
                device.destroy_semaphore(*semaphore, None);
            }
        }
        for fence in &self.in_flight_fences {
            unsafe {
                device.destroy_fence(*fence, None);
            }
        }
        self.image_available_semaphores.clear();
        self.render_finished_semaphores.clear();
        self.in_flight_fences.clear();
        
        // Clean up surface
        if let Some(surface) = self.surface {
            unsafe {
                let instance = self.instance.as_ref().unwrap();
                instance.destroy_surface_khr(surface, None);
            }
        }
        self.surface = None;
        
        // Clean up device
        if let Some(device) = self.device.take() {
            unsafe {
                device.destroy_device(None);
            }
        }
        
        // Clean up allocator
        if let Some(allocator) = self.allocator.take() {
            drop(allocator);
        }
        
        // Clean up instance
        if let Some(instance) = self.instance.take() {
            unsafe {
                instance.destroy_instance(None);
            }
        }
        
        println!("Vulkan resources cleaned up successfully");
    }

    /// Delete a buffer
    #[cfg(feature = "vulkan")]
    pub fn delete_buffer(&mut self, buffer_id: usize) {
        if let Some(vulkan_buffer) = self.buffers.remove(&buffer_id) {
            let device = self.device.as_ref().unwrap();
            unsafe {
                device.destroy_buffer(vulkan_buffer.buffer, None);
                // Note: In a real implementation, we would also free the allocation
            }
        }
    }

    /// Delete a texture
    #[cfg(feature = "vulkan")]
    pub fn delete_texture(&mut self, texture_id: usize) {
        if let Some(vulkan_texture) = self.textures.remove(&texture_id) {
            let device = self.device.as_ref().unwrap();
            unsafe {
                device.destroy_image_view(vulkan_texture.image_view, None);
                device.destroy_sampler(vulkan_texture.sampler, None);
                device.destroy_image(vulkan_texture.image, None);
                // Note: In a real implementation, we would also free the allocation
            }
        }
    }

    /// Create a cube map texture
    #[cfg(feature = "vulkan")]
    pub fn create_cubemap_texture(&mut self, width: u32, height: u32, face_data: &[&[u8]; 6]) -> Result<usize, VulkanError> {
        let device = self.device.as_ref().unwrap();
        let allocator = self.allocator.as_ref().unwrap();
        
        // Create cube map image
        let create_info = vk::ImageCreateInfo {
            image_type: vk::ImageType::TYPE_2D,
            extent: vk::Extent3D {
                width,
                height,
                depth: 1,
            },
            mip_levels: 1,
            array_layers: 6,
            format: vk::Format::R8G8B8A8_SRGB,
            tiling: vk::ImageTiling::OPTIMAL,
            initial_layout: vk::ImageLayout::UNDEFINED,
            usage: vk::ImageUsageFlags::TRANSFER_DST | vk::ImageUsageFlags::SAMPLED,
            sharing_mode: vk::SharingMode::EXCLUSIVE,
            samples: vk::SampleCountFlags::TYPE_1,
            flags: vk::ImageCreateFlags::CUBE_COMPATIBLE,
            ..Default::default()
        };
            
        let image = unsafe {
            device.create_image(&create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create cube map image: {}", e)))?
        };
        
        // Allocate memory
        let requirements = unsafe { device.get_image_memory_requirements(image) };
        let allocation_create_desc = gpu_allocator::vulkan::AllocationCreateDesc {
            name: "CubeMap",
            requirements,
            location: MemoryLocation::GpuOnly,
            linear: false,
            allocation_scheme: gpu_allocator::vulkan::AllocationScheme::DedicatedImage(image),
        };
        
        let allocation = allocator.alloc(&allocation_create_desc)
            .map_err(|e| VulkanError::AllocationFailed(format!("Failed to allocate cube map memory: {}", e)))?;
        
        unsafe {
            device.bind_image_memory(image, allocation.memory(), allocation.offset())
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to bind cube map memory: {}", e)))?
        }
        
        // Create image view for cube map
        let view_create_info = vk::ImageViewCreateInfo {
            image,
            view_type: vk::ImageViewType::CUBE,
            format: vk::Format::R8G8B8A8_SRGB,
            components: vk::ComponentMapping {
                r: vk::ComponentSwizzle::IDENTITY,
                g: vk::ComponentSwizzle::IDENTITY,
                b: vk::ComponentSwizzle::IDENTITY,
                a: vk::ComponentSwizzle::IDENTITY,
            },
            subresource_range: vk::ImageSubresourceRange {
                aspect_mask: vk::ImageAspectFlags::COLOR,
                base_mip_level: 0,
                level_count: 1,
                base_array_layer: 0,
                layer_count: 6,
            },
            ..Default::default()
        };
            
        let image_view = unsafe {
            device.create_image_view(&view_create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create cube map image view: {}", e)))?
        };
        
        // Create sampler
        let sampler_info = vk::SamplerCreateInfo {
            mag_filter: vk::Filter::LINEAR,
            min_filter: vk::Filter::LINEAR,
            address_mode_u: vk::SamplerAddressMode::REPEAT,
            address_mode_v: vk::SamplerAddressMode::REPEAT,
            address_mode_w: vk::SamplerAddressMode::REPEAT,
            anisotropy_enable: vk::TRUE,
            max_anisotropy: 16.0,
            border_color: vk::BorderColor::INT_OPAQUE_BLACK,
            unnormalized_coordinates: vk::FALSE,
            compare_enable: vk::FALSE,
            compare_op: vk::CompareOp::ALWAYS,
            mipmap_mode: vk::SamplerMipmapMode::LINEAR,
            mip_lod_bias: 0.0,
            min_lod: 0.0,
            max_lod: vk::LOD_CLAMP_NONE,
            ..Default::default()
        };
            
        let sampler = unsafe {
            device.create_sampler(&sampler_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create cube map sampler: {}", e)))?
        };
        
        // Upload cube map data for each face
        for (face_index, &face_data) in face_data.iter().enumerate() {
            if !face_data.is_empty() {
                self.update_cubemap_face_data(image, face_data, width, height, face_index as u32)?;
            }
        }
        
        let texture_id = self.next_texture_id;
        self.next_texture_id += 1;
        
        self.textures.insert(texture_id, VulkanTexture {
            image,
            image_view,
            allocation,
            sampler,
            width,
            height,
            format: vk::Format::R8G8B8A8_SRGB,
        });
        
        Ok(texture_id)
    }

    /// Update a specific face of a cube map
    #[cfg(feature = "vulkan")]
    pub fn update_cubemap_face_data(&mut self, image: vk::Image, data: &[u8], width: u32, height: u32, face: u32) -> Result<(), VulkanError> {
        let device = self.device.as_ref().unwrap();
        let command_pool = self.command_pool.ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Create staging buffer
        let staging_buffer_id = self.create_buffer(
            data.len() as vk::DeviceSize,
            vk::BufferUsageFlags::TRANSFER_SRC,
            MemoryLocation::CpuToGpu,
        )?;
        
        let staging_buffer = &self.buffers[&staging_buffer_id];
        
        // Upload data to staging buffer
        unsafe {
            let mut staging_data = std::ptr::null_mut();
            
            // Fix map_memory call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                let result = device.map_memory(staging_buffer.allocation.memory(), data.len().try_into().unwrap(), &mut staging_data);
                match result {
                    Ok(()) => {
                        std::ptr::copy_nonoverlapping(data.as_ptr(), staging_data as *mut u8, data.len());
                        device.unmap_memory(staging_buffer.allocation.memory());
                    }
                    Err(err) => return Err(VulkanError::MappingFailed(format!("Failed to map staging buffer memory: {:?}", err))),
                }
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                let result = device.map_memory(staging_buffer.allocation.memory(), staging_buffer.allocation.offset(), data.len(), vk::MemoryMapFlags::empty(), &mut staging_data);
                match result {
                    vk::Result::SUCCESS => {
                        std::ptr::copy_nonoverlapping(data.as_ptr(), staging_data as *mut u8, data.len());
                        device.unmap_memory(staging_buffer.allocation.memory());
                    }
                    err => return Err(VulkanError::MappingFailed(format!("Failed to map staging buffer memory: {:?}", err))),
                }
            }
        
        // Create command buffer
        let command_buffer_allocate_info = vk::CommandBufferAllocateInfo {
            command_pool,
            level: vk::CommandBufferLevel::PRIMARY,
            command_buffer_count: 1,
            ..Default::default()
        };
        
        let command_buffers = unsafe {
            device.allocate_command_buffers(&command_buffer_allocate_info)
                .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to allocate cubemap face command buffer: {}", e)))?
        };
        
        let command_buffer = command_buffers[0];
        
        // Begin command buffer
        let begin_info = vk::CommandBufferBeginInfo {
            flags: vk::CommandBufferUsageFlags::ONE_TIME_SUBMIT,
            ..Default::default()
        };
        
        unsafe {
            device.begin_command_buffer(command_buffer, &begin_info)
                .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to begin cubemap face command buffer: {}", e)))?;
        }
        
        // Transition image layer to transfer destination
        let layer_subresource = vk::ImageSubresourceLayers {
            aspect_mask: vk::ImageAspectFlags::COLOR,
            mip_level: 0,
            base_array_layer: face,
            layer_count: 1,
        };
        
        let image_memory_barrier = vk::ImageMemoryBarrier {
            s_type: vk::StructureType::IMAGE_MEMORY_BARRIER,
            p_next: std::ptr::null(),
            src_access_mask: vk::AccessFlags::MEMORY_WRITE,
            dst_access_mask: vk::AccessFlags::TRANSFER_WRITE,
            old_layout: vk::ImageLayout::UNDEFINED,
            new_layout: vk::ImageLayout::TRANSFER_DST_OPTIMAL,
            src_queue_family_index: vk::QUEUE_FAMILY_IGNORED,
            dst_queue_family_index: vk::QUEUE_FAMILY_IGNORED,
            image,
            subresource_range: vk::ImageSubresourceRange {
                aspect_mask: vk::ImageAspectFlags::COLOR,
                base_mip_level: 0,
                level_count: 1,
                base_array_layer: face,
                layer_count: 1,
            },
            ..Default::default()
        };
        
        unsafe {
            device.cmd_pipeline_barrier(
                command_buffer,
                vk::PipelineStageFlags::TOP_OF_PIPE,
                vk::PipelineStageFlags::TRANSFER,
                vk::DependencyFlags::empty(),
                0, std::ptr::null(),
                0, std::ptr::null(),
                1, [image_memory_barrier].as_ptr()
            );
        }
        
        // Copy buffer to specific face
        let buffer_to_image = vk::BufferImageCopy {
            buffer_offset: 0,
            buffer_row_length: 0,
            buffer_image_height: 0,
            image_subresource: layer_subresource,
            image_offset: vk::Offset3D { x: 0, y: 0, z: 0 },
            image_extent: vk::Extent3D { width, height, depth: 1 },
        };
        
        // Fix cmd_copy_buffer_to_image call for ash v0.38 compatibility
        #[cfg(feature = "ash_038")]
        {
            device.cmd_copy_buffer_to_image(
                command_buffer,
                staging_buffer.buffer,
                image,
                vk::ImageLayout::TRANSFER_DST_OPTIMAL,
                &[buffer_to_image]
            );
        }
        
        #[cfg(not(feature = "ash_038"))]
        {
            device.cmd_copy_buffer_to_image(
                command_buffer,
                staging_buffer.buffer,
                image,
                vk::ImageLayout::TRANSFER_DST_OPTIMAL,
                1,
                [buffer_to_image].as_ptr()
            );
        }
        
        // End command buffer
        device.end_command_buffer(command_buffer)
            .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to end cubemap face command buffer: {}", e)))?;
        
        // Submit command buffer
        let submit_info = vk::SubmitInfo {
            p_command_buffers: &command_buffer,
            ..Default::default()
        };
        
        let graphics_queue = self.graphics_queue.ok_or(VulkanError::DeviceNotInitialized)?;
        
        unsafe {
            device.queue_submit(graphics_queue, &[submit_info], vk::Fence::null())
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to submit cubemap face upload: {}", e)))?;
            
            device.queue_wait_idle(graphics_queue)
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to wait for cubemap face upload: {}", e)))?;
            
            device.free_command_buffers(command_pool, &[command_buffer]);
        }
        
        // Clean up staging buffer
        self.delete_buffer(staging_buffer_id);
        
        Ok(())
    }

    /// Create a depth texture
    #[cfg(feature = "vulkan")]
    pub fn create_depth_texture(&mut self, width: u32, height: u32) -> Result<usize, VulkanError> {
        let device = self.device.as_ref().unwrap();
        let allocator = self.allocator.as_ref().unwrap();
        
        // Create depth image
        let create_info = vk::ImageCreateInfo {
            image_type: vk::ImageType::TYPE_2D,
            extent: vk::Extent3D {
                width,
                height,
                depth: 1,
            },
            mip_levels: 1,
            array_layers: 1,
            format: vk::Format::D32_SFLOAT,
            tiling: vk::ImageTiling::OPTIMAL,
            initial_layout: vk::ImageLayout::UNDEFINED,
            usage: vk::ImageUsageFlags::DEPTH_STENCIL_ATTACHMENT | vk::ImageUsageFlags::SAMPLED,
            sharing_mode: vk::SharingMode::EXCLUSIVE,
            samples: vk::SampleCountFlags::TYPE_1,
            ..Default::default()
        };
            
        let image = unsafe {
            device.create_image(&create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create depth image: {}", e)))?
        };
        
        // Allocate memory
        let requirements = unsafe { device.get_image_memory_requirements(image) };
        let allocation_create_desc = gpu_allocator::vulkan::AllocationCreateDesc {
            name: "DepthTexture",
            requirements,
            location: MemoryLocation::GpuOnly,
            linear: false,
            allocation_scheme: gpu_allocator::vulkan::AllocationScheme::DedicatedImage(image),
        };
        
        let allocation = allocator.alloc(&allocation_create_desc)
            .map_err(|e| VulkanError::AllocationFailed(format!("Failed to allocate depth texture memory: {}", e)))?;
        
        unsafe {
            device.bind_image_memory(image, allocation.memory(), allocation.offset())
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to bind depth texture memory: {}", e)))?
        }
        
        // Create image view
        let view_create_info = vk::ImageViewCreateInfo {
            image,
            view_type: vk::ImageViewType::TYPE_2D,
            format: vk::Format::D32_SFLOAT,
            components: vk::ComponentMapping {
                r: vk::ComponentSwizzle::IDENTITY,
                g: vk::ComponentSwizzle::IDENTITY,
                b: vk::ComponentSwizzle::IDENTITY,
                a: vk::ComponentSwizzle::IDENTITY,
            },
            subresource_range: vk::ImageSubresourceRange {
                aspect_mask: vk::ImageAspectFlags::DEPTH,
                base_mip_level: 0,
                level_count: 1,
                base_array_layer: 0,
                layer_count: 1,
            },
            ..Default::default()
        };
            
        let image_view = unsafe {
            device.create_image_view(&view_create_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create depth image view: {}", e)))?
        };
        
        // Create sampler for depth texture
        let sampler_info = vk::SamplerCreateInfo {
            mag_filter: vk::Filter::LINEAR,
            min_filter: vk::Filter::LINEAR,
            address_mode_u: vk::SamplerAddressMode::CLAMP_TO_EDGE,
            address_mode_v: vk::SamplerAddressMode::CLAMP_TO_EDGE,
            address_mode_w: vk::SamplerAddressMode::CLAMP_TO_EDGE,
            anisotropy_enable: vk::FALSE,
            border_color: vk::BorderColor::FLOAT_OPAQUE_WHITE,
            unnormalized_coordinates: vk::FALSE,
            compare_enable: vk::FALSE,
            compare_op: vk::CompareOp::ALWAYS,
            mipmap_mode: vk::SamplerMipmapMode::LINEAR,
            mip_lod_bias: 0.0,
            min_lod: 0.0,
            max_lod: vk::LOD_CLAMP_NONE,
            ..Default::default()
        };
            
        let sampler = unsafe {
            device.create_sampler(&sampler_info, None)
                .map_err(|e| VulkanError::InitializationFailed(format!("Failed to create depth sampler: {}", e)))?
        };
        
        let texture_id = self.next_texture_id;
        self.next_texture_id += 1;
        
        self.textures.insert(texture_id, VulkanTexture {
            image,
            image_view,
            allocation,
            sampler,
            width,
            height,
            format: vk::Format::D32_SFLOAT,
        });
        
        Ok(texture_id)
    }

    /// Recreate swapchain (for window resize)
    #[cfg(feature = "vulkan")]
    pub fn recreate_swapchain(&mut self, display: &dyn NativeDisplay) -> Result<(), VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Clean up existing swapchain resources
        for framebuffer in &self.framebuffers {
            unsafe {
                device.destroy_framebuffer(*framebuffer, None);
            }
        }
        self.framebuffers.clear();
        
        for image_view in &self.swapchain_image_views {
            unsafe {
                device.destroy_image_view(*image_view, None);
            }
        }
        self.swapchain_image_views.clear();
        
        if let Some(swapchain) = self.swapchain {
            unsafe {
                vk::SwapchainCreateInfoKHR::load().destroy_swapchain_khr(device, swapchain, None);
            }
        }
        self.swapchain = None;
        self.swapchain_images.clear();
        
        // Recreate swapchain
        self.create_swapchain(display)?;
        
        // Recreate render pass
        self.create_render_pass()?;
        
        // Recreate framebuffers
        self.create_framebuffers()?;
        
        // Recreate command buffers
        self.create_command_buffers()?;
        
        Ok(())
    }

    /// Present the current frame
    #[cfg(feature = "vulkan")]
    pub fn present(&mut self) -> Result<(), VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        let swapchain = self.swapchain.ok_or(VulkanError::DeviceNotInitialized)?;
        let present_queue = self.present_queue.ok_or(VulkanError::DeviceNotInitialized)?;
        
        // Wait for fence to ensure previous frame is complete
        unsafe {
            device.wait_for_fences(
                &[self.in_flight_fences[self.current_frame]], 
                true, 
                std::u64::MAX
            ).map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to wait for fence: {}", e)))?;
            
            device.reset_fences(&[self.in_flight_fences[self.current_frame]])
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to reset fence: {}", e)))?;
        }
        
        // Acquire next image
        let (image_index, _) = unsafe {
            // Fix acquire_next_image_khr call for ash v0.38 compatibility
            #[cfg(feature = "ash_038")]
            {
                vk::KhrSwapchainFn::load()
                    .acquire_next_image_khr(
                        device, 
                        swapchain, 
                        std::u64::MAX, 
                        self.image_available_semaphores[self.current_frame], 
                        vk::Fence::null()
                    )
                    .map_err(|e| VulkanError::WindowError(format!("Failed to acquire next image: {}", e)))?
            }
            
            #[cfg(not(feature = "ash_038"))]
            {
                vk::SwapchainCreateInfoKHR::load()
                    .acquire_next_image_khr(
                        device, 
                        swapchain, 
                        std::u64::MAX, 
                        self.image_available_semaphores[self.current_frame], 
                        vk::Fence::null()
                    )
                    .map_err(|e| VulkanError::WindowError(format!("Failed to acquire next image: {}", e)))?
            }
        };
        
        // Update image in flight tracking
        if let Some(fence) = self.images_in_flight[image_index as usize] {
            unsafe {
                device.wait_for_fences(&[fence], true, std::u64::MAX)
                    .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to wait for in-flight fence: {}", e)))?;
            }
        }
        self.images_in_flight[image_index as usize] = Some(self.in_flight_fences[self.current_frame]);
        
        // Submit command buffer
        let wait_semaphores = [self.image_available_semaphores[self.current_frame]];
        let signal_semaphores = [self.render_finished_semaphores[self.current_frame]];
        let command_buffers = [self.command_buffers[image_index as usize]];
        
        let submit_info = vk::SubmitInfo {
            p_wait_semaphores: wait_semaphores.as_ptr(),
            wait_semaphore_count: wait_semaphores.len() as u32,
            p_wait_dst_stage_mask: [vk::PipelineStageFlags::COLOR_ATTACHMENT_OUTPUT].as_ptr(),
            p_command_buffers: command_buffers.as_ptr(),
            command_buffer_count: command_buffers.len() as u32,
            p_signal_semaphores: signal_semaphores.as_ptr(),
            signal_semaphore_count: signal_semaphores.len() as u32,
            ..Default::default()
        };
        
        unsafe {
            device.queue_submit(present_queue, &[submit_info], self.in_flight_fences[self.current_frame])
                .map_err(|e| VulkanError::SynchronizationFailed(format!("Failed to submit command buffer: {}", e)))?;
        }
        
        // Present the image
        let swapchains = [swapchain];
        let image_indices = [image_index];
        let present_info = vk::PresentInfoKHR {
            s_type: vk::StructureType::PRESENT_INFO_KHR,
            p_next: std::ptr::null(),
            wait_semaphore_count: signal_semaphores.len() as u32,
            p_wait_semaphores: signal_semaphores.as_ptr(),
            swapchain_count: swapchains.len() as u32,
            p_swapchains: swapchains.as_ptr(),
            p_image_indices: image_indices.as_ptr(),
            p_results: std::ptr::null_mut(),
            ..Default::default()
        };
        
        unsafe {
            vk::SwapchainCreateInfoKHR::load()
                .queue_present_khr(present_queue, &present_info)
                .map_err(|e| VulkanError::WindowError(format!("Failed to present image: {}", e)))?;
        }
        
        // Update frame index
        self.current_frame = (self.current_frame + 1) % self.max_frames_in_flight;
        
        Ok(())
    }

    /// Begin command buffer recording for current frame
    #[cfg(feature = "vulkan")]
    pub fn begin_frame(&mut self) -> Result<(), VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        let framebuffer = &self.framebuffers[self.current_frame];
        
        let command_buffer = self.command_buffers[self.current_frame];
        
        let begin_info = vk::CommandBufferBeginInfo {
            s_type: vk::StructureType::COMMAND_BUFFER_BEGIN_INFO,
            p_next: std::ptr::null(),
            flags: vk::CommandBufferUsageFlags::SIMULTANEOUS_USE,
            p_inheritance_info: std::ptr::null(),
            ..Default::default()
        };
        
        unsafe {
            device.begin_command_buffer(command_buffer, &begin_info)
                .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to begin command buffer: {}", e)))?;
        }
        
        // Begin render pass
        let render_pass_begin = vk::RenderPassBeginInfo {
            s_type: vk::StructureType::RENDER_PASS_BEGIN_INFO,
            p_next: std::ptr::null(),
            render_pass: self.render_pass.unwrap(),
            framebuffer: *framebuffer,
            render_area: vk::Rect2D {
                offset: vk::Offset2D { x: 0, y: 0 },
                extent: self.swapchain_extent,
            },
            clear_value_count: 1,
            p_clear_values: [vk::ClearValue {
                color: vk::ClearColorValue {
                    float32: [0.0, 0.0, 0.0, 1.0],
                },
            }].as_ptr(),
            ..Default::default()
        };
        
        unsafe {
            device.cmd_begin_render_pass(command_buffer, &render_pass_begin, vk::SubpassContents::INLINE);
        }
        
        Ok(())
    }

    /// End command buffer recording for current frame
    #[cfg(feature = "vulkan")]
    pub fn end_frame(&mut self) -> Result<(), VulkanError> {
        let device = self.device.as_ref().ok_or(VulkanError::DeviceNotInitialized)?;
        let command_buffer = self.command_buffers[self.current_frame];
        
        unsafe {
            device.cmd_end_render_pass(command_buffer);
            device.end_command_buffer(command_buffer)
                .map_err(|e| VulkanError::CommandBufferCreationFailed(format!("Failed to end command buffer: {}", e)))?;
        }
        
        Ok(())
    }
}

impl Default for VulkanContext {
    fn default() -> Self {
        Self::new()
    }
}